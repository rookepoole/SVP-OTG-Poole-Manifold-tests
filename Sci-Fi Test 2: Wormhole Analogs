# POOLE MANIFOLD — Sci-Fi Test 2: Wormhole Analogs
# Two distant mouths connected by a thin filament tunnel
# =============================================================================

import torch
import torch.nn.functional as F
import numpy as np
import matplotlib.pyplot as plt
from IPython.display import clear_output

device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print(f"🚀 Sci-Fi Test 2 — Wormhole Analogs on: {device}")

GRID_SIZE = 192
B_LOW, B_HIGH = 5.0, 7.0
S_LOW, S_HIGH = 5.0, 9.0
PRIMES = [2, 3, 5, 7, 11, 13, 17, 19, 23]

kernel = torch.ones((1, 1, 3, 3, 3), device=device).float()
kernel[0, 0, 1, 1, 1] = 0

def run_manifold(f):
    with torch.no_grad():
        padded = F.pad(f.float(), (1,1,1,1,1,1), mode='circular')
        potential = F.conv3d(padded, kernel)
        resonance = torch.zeros_like(potential)
        for p in PRIMES:
            resonance += 0.35 * torch.exp(-((potential - p)**2) / 0.01)
        total_phi = potential + resonance
        birth = (f == 0) & (total_phi >= B_LOW) & (total_phi <= B_HIGH)
        survive = (f == 1) & (total_phi >= S_LOW) & (total_phi <= S_HIGH)
        return (birth | survive).float()

# Initialize
field = torch.zeros((1, 1, GRID_SIZE, GRID_SIZE, GRID_SIZE), device=device)
field = (torch.rand_like(field) > 0.69).float()

# Wormhole Mouth 1 (left)
mouth1_y, mouth1_x, mouth1_z = GRID_SIZE//2, 40, GRID_SIZE//2
field[0, 0, mouth1_z-12:mouth1_z+12, mouth1_y-12:mouth1_y+12, mouth1_x-12:mouth1_x+12] = 1.0

# Wormhole Mouth 2 (right)
mouth2_y, mouth2_x, mouth2_z = GRID_SIZE//2, GRID_SIZE-40, GRID_SIZE//2
field[0, 0, mouth2_z-12:mouth2_z+12, mouth2_y-12:mouth2_y+12, mouth2_x-12:mouth2_x+12] = 1.0

# Thin filament "throat" connecting the two mouths
throat_y, throat_x_start, throat_z = GRID_SIZE//2, 52, GRID_SIZE//2
field[0, 0, throat_z-3:throat_z+3, throat_y-3:throat_y+3, throat_x_start:throat_x_start+(GRID_SIZE-104)] = 1.0

print("Wormhole mouths + throat seeded. Stabilizing...")

for _ in range(600):
    field = run_manifold(field)

print("✅ Wormhole test running! Sending test gliders through the tunnel...\n")

# Send test gliders into Mouth 1 and watch if they emerge from Mouth 2
for gen in range(2400):
    field = run_manifold(field)
    
    # Inject glider into Mouth 1 every 400 generations
    if gen % 400 == 0:
        field[0, 0, mouth1_z+2:mouth1_z+6, mouth1_y+2:mouth1_y+6, mouth1_x+2:mouth1_x+6] = 1.0
    
    if gen % 20 == 0:
        slice_mid = field[0, 0, GRID_SIZE//2, :, :].cpu().numpy()
        
        clear_output(wait=True)
        fig, axs = plt.subplots(1, 2, figsize=(16, 7), facecolor='black')
        
        axs[0].imshow(slice_mid, cmap='inferno')
        # Highlight mouths
        rect1 = plt.Rectangle((mouth1_x-12, mouth1_y-12), 24, 24, linewidth=2, edgecolor='cyan', facecolor='none')
        rect2 = plt.Rectangle((mouth2_x-12, mouth2_y-12), 24, 24, linewidth=2, edgecolor='cyan', facecolor='none')
        axs[0].add_patch(rect1)
        axs[0].add_patch(rect2)
        axs[0].set_title(f"Wormhole Test (Gen {gen})", color='white')
        axs[0].axis('off')
        
        # Mass in Mouth 2 (exit) as proxy for successful transit
        mouth2_mass = field[0, 0, mouth2_z-12:mouth2_z+12, mouth2_y-12:mouth2_y+12, mouth2_x-12:mouth2_x+12].sum().item()
        axs[1].plot([gen], [mouth2_mass], 'co', label='Mouth 2 Mass' if gen == 0 else "")
        axs[1].set_title("Test Glider Transit — Mass at Exit Mouth", color='white')
        axs[1].set_xlabel("Generation", color='white')
        axs[1].set_ylabel("Mass in Exit Mouth", color='white')
        axs[1].grid(True, alpha=0.3)
        
        plt.show()
        
        print(f"Gen {gen:4d} | Mass in Exit Mouth: {mouth2_mass:.1f}")

print("\n✅ Test 2 complete!")
print("If mass appears in the right mouth shortly after injecting into the left mouth,")
print("the lattice is supporting wormhole-like shortcut travel.")

# Final summary plot
plt.figure(figsize=(10, 5), facecolor='black')
# (We would normally collect mouth2_mass_history, but for simplicity we just show the final state)
plt.title("Wormhole Transit Test — Final State", color='white')
plt.imshow(field[0, 0, GRID_SIZE//2].cpu().numpy(), cmap='inferno')
plt.axis('off')
plt.show()# =============================================================================
