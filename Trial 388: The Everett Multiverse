# Mass Correlation Graph
plt.figure(figsize=(15, 4), facecolor='black')
# Use twinx because Universe A's mass will be violently high, while B's will be precise and stable
ax1 = plt.gca()
ax2 = ax1.twinx()

ax1.plot(mass_A_log, color='magenta', linewidth=2, label='Universe A (Reactor Mass)')
ax1.fill_between(range(len(mass_A_log)), mass_A_log, color='magenta', alpha=0.2)
