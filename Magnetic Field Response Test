import torch
import torch.nn.functional as F
import numpy as np
import matplotlib.pyplot as plt
from IPython.display import clear_output

device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
print(f"Using device: {device} — Magnetic Field Response Test online!")
def poole_manifold_step(grid):
    kernel = torch.ones((1, 1, 3, 3, 3), device=device, dtype=torch.float32)
    kernel[0, 0, 1, 1, 1] = 0
    padded = F.pad(grid.unsqueeze(0).unsqueeze(0), (1,1,1,1,1,1), mode='circular')
    neighbor_sum = F.conv3d(padded, kernel, padding=0).squeeze(0).squeeze(0)
    
    born = (neighbor_sum >= 5) & (neighbor_sum <= 7) & (grid == 0)
    survive = (neighbor_sum >= 5) & (neighbor_sum <= 9) & (grid == 1)
    return (born | survive).float()

print("✅ Poole Manifold engine ready!")
np.random.seed(42)
size = 80
grid_np = np.zeros((size, size, size), dtype=np.float32)

# Cosmic web filaments
for _ in range(220):
    x = np.random.randint(0, size)
    y = np.random.randint(0, size)
    z = np.random.randint(0, size)
    length = np.random.randint(25, 55)
    dx = np.random.randn() * 1.3
    dy = np.random.randn() * 1.3
    dz = np.random.randn() * 1.3
    for i in range(length):
        ix = int(x + i * dx) % size
        iy = int(y + i * dy) % size
        iz = int(z + i * dz) % size
        if 0 <= ix < size and 0 <= iy < size and 0 <= iz < size:
            grid_np[ix, iy, iz] = 1.0

noise = np.random.choice([0, 1], size=(size, size, size), p=[0.85, 0.15])
grid_np = np.clip(grid_np + noise, 0, 1)

grid = torch.from_numpy(grid_np).float().to(device)

# Magnetic field (horizontal along X for simplicity)
magnetic_field = torch.ones((size, size, size), device=device, dtype=torch.float32) * 0.8  # uniform field strength

print(f"Porous network + magnetic field initialized — {grid.sum().item():.0f} solid cells")
steps = 3000
density_history = []
alignment_history = []

print("Running NEW FIXED Magnetic Field Response Test...")

for step in range(steps):
    grid = poole_manifold_step(grid)
    
    # === NEW GENTLE POST-STEP MAGNETIC REORIENTATION ===
    if step > 500 and step % 20 == 0:   # only after stabilization, and infrequently
        x_coords = torch.arange(size, device=device).view(-1, 1, 1).expand_as(grid)
        field_alignment = 1 - (torch.abs(x_coords - size//2) / (size//2))
        
        # Extremely light nudge: only on live cells, very small probability
        nudge_mask = (grid > 0.5) & (torch.rand_like(grid) < 0.03)
        grid[nudge_mask] = torch.where(field_alignment[nudge_mask] > 0.7, 1.0, grid[nudge_mask])
    
    # Alignment score (how well live cells align with field)
    x_coords = torch.arange(size, device=device).view(-1, 1, 1).expand_as(grid)
    field_alignment = 1 - (torch.abs(x_coords - size//2) / (size//2))
    alignment = (grid * field_alignment).mean().item()
    
    if step % 500 == 0 or step == steps-1:
        density = grid.mean().item()
        density_history.append((step, density))
        alignment_history.append((step, alignment))
        print(f"Step {step:4d} | Density: {density:.4f} | Alignment score: {alignment:.4f}")
        
        if step % 1000 == 0 or step == steps-1:
            clear_output(wait=True)
            center = size // 2
            fig, axes = plt.subplots(1, 3, figsize=(15,5))
            axes[0].imshow(grid[center].cpu().numpy(), cmap='binary')
            axes[0].set_title('Solid network (XY)')
            axes[1].imshow(grid[:, center, :].cpu().numpy(), cmap='binary')
            axes[1].set_title('Aligned view (XZ)')
            axes[2].imshow(grid[:, :, center].cpu().numpy(), cmap='binary')
            axes[2].set_title('Aligned view (YZ)')
            plt.suptitle(f"NEW FIXED Magnetic Field Response — Step {step}")
            plt.show()

print("\n✅ NEW FIXED Magnetic Field Response test finished!")
steps_list, dens_list = zip(*density_history)
a_steps, a_list = zip(*alignment_history)

plt.figure(figsize=(10,5))
plt.plot(steps_list, dens_list, 'b-', label='Solid density')
plt.axhline(y=0.31, color='r', linestyle='--', label='Phoenix ~31%')
plt.title('Density during Magnetic Test')
plt.legend()
plt.grid(True)
plt.show()

plt.figure(figsize=(10,5))
plt.plot(a_steps, a_list, 'purple', label='Alignment score')
plt.title('Magnetic Alignment Over Time')
plt.xlabel('Step')
plt.ylabel('Alignment with field')
plt.legend()
plt.grid(True)
plt.show()

final_grid = grid.cpu().numpy() > 0.5
porosity = 1 - final_grid.mean()
print(f"Porosity: {porosity:.4f} ({porosity*100:.1f}%)")
print(f"Final alignment score: {a_list[-1]:.4f}")

np.save('magnetic_final_grid.npy', final_grid.astype(np.uint8))
print("Saved magnetic data!")
