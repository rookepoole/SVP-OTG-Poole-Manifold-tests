import torch
import torch.nn.functional as F

device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print(f"🚀 Initializing Corrected RG Flow Test on: {device}")

# --- Cosmology & Engine Parameters ---
B_LOW, B_HIGH = 5.0, 7.0
S_LOW, S_HIGH = 5.0, 9.0
GRID_SIZE = 512
PRIMES = [2, 3, 5, 7, 11, 13, 17, 19, 23]
MEMORY_FIELD_COUPLING = 0.005 # Non-conservative energy injection

# 3D Moore Neighborhood Kernel
kernel = torch.ones((1, 1, 3, 3, 3), device=device).float()
kernel[0, 0, 1, 1, 1] = 0

def run_poole_with_memory(f, memory_field):
    """Executes B5-7/S5-9 with Prime Resonance and Non-Conservative Memory Influx"""
    with torch.no_grad():
        padded = F.pad(f.float(), (1,1,1,1,1,1), mode='circular')
        potential = F.conv3d(padded, kernel)
        
        resonance = torch.zeros_like(potential)
        for p in PRIMES:
            resonance += 0.35 * torch.exp(-((potential - p)**2) / 0.01)
            
        total_phi = potential + resonance
        
        # Base cellular rules
        birth = (f == 0) & (total_phi >= B_LOW) & (total_phi <= B_HIGH)
        survive = (f == 1) & (total_phi >= S_LOW) & (total_phi <= S_HIGH)
        
        # Non-conservative Geometric Memory Field injection
        memory_field = memory_field * 0.99 + (birth.float() * 0.01) 
        spontaneous_birth = (f == 0) & (torch.rand_like(f) < (memory_field * MEMORY_FIELD_COUPLING))
        
        new_state = (birth | survive | spontaneous_birth).float()
        
        # Calculate raw state changes
        state_changes = torch.abs(new_state - f).sum().item()
        
        return new_state, memory_field, state_changes

def coarse_grain_universe(f):
    """
    Corrected RG Flow Transformation: Strict Majority Vote.
    Takes 2x2x2 micro-voxels and averages them. 
    Requires >= 0.5 density (4+ active cells) to become an active macro-cell.
    """
    with torch.no_grad():
        macro_f = F.avg_pool3d(f, kernel_size=2, stride=2)
        macro_f_discrete = (macro_f >= 0.5).float()
        return macro_f_discrete

# === INITIALIZATION ===
print(f"\n[1] Seeding {GRID_SIZE}^3 Micro-Universe...")
field = torch.zeros((1, 1, GRID_SIZE, GRID_SIZE, GRID_SIZE), device=device)
memory_field = torch.zeros_like(field)

# Seed a massive central attractor
c = GRID_SIZE // 2
field[0, 0, c-40:c+40, c-40:c+40, c-40:c+40] = (torch.rand(80, 80, 80, device=device) > 0.5).float()

print("[2] Burning in Phoenix Attractor & Memory Field (100 gens)...")
for _ in range(100):
    field, memory_field, _ = run_poole_with_memory(field, memory_field)

# === THE CORRECTED SCALE INVARIANCE TEST ===
print("\n[3] INITIATING CORRECTED RENORMALIZATION GROUP (RG) FLOW TEST")
print("Applying Strict Majority Vote & Time Dilation (2 Micro-Steps = 1 Macro-Step)")
print("-" * 80)

for t in range(1, 6):
    # MICRO UNIVERSE: Run TWO steps to cover the correct spacetime distance
    field, memory_field, micro_changes_1 = run_poole_with_memory(field, memory_field)
    field, memory_field, micro_changes_2 = run_poole_with_memory(field, memory_field)
    
    micro_total_changes = micro_changes_1 + micro_changes_2
    micro_flux = micro_total_changes / (GRID_SIZE**3)
    
    # MACRO UNIVERSE: Coarse-grain the current state, then run ONE step
    macro_field = coarse_grain_universe(field)
    macro_memory_field = coarse_grain_universe(memory_field)
    
    macro_new_state, _, macro_changes = run_poole_with_memory(macro_field, macro_memory_field)
    
    macro_vol = (GRID_SIZE // 2)**3
    macro_flux = macro_changes / macro_vol

    # Calculate effective H0 expansion proxy
    micro_H0 = micro_flux * 72.88 / 0.3095 
    macro_H0 = macro_flux * 72.88 / 0.3095

    deviation = abs(micro_H0 - macro_H0)

    print(f"Gen {t:02d} | Micro H0: {micro_H0:.4f} km/s/Mpc | Macro H0: {macro_H0:.4f} km/s/Mpc | Deviation: {deviation:.4f}")

