import torch
import torch.nn.functional as F
import numpy as np
import matplotlib.pyplot as plt
from IPython.display import clear_output

device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
print(f"Using device: {device} — Thermal Conduction Test online!")
def poole_manifold_step(grid):
    kernel = torch.ones((1, 1, 3, 3, 3), device=device, dtype=torch.float32)
    kernel[0, 0, 1, 1, 1] = 0
    padded = F.pad(grid.unsqueeze(0).unsqueeze(0), (1,1,1,1,1,1), mode='circular')
    neighbor_sum = F.conv3d(padded, kernel, padding=0).squeeze(0).squeeze(0)
    
    born = (neighbor_sum >= 5) & (neighbor_sum <= 7) & (grid == 0)
    survive = (neighbor_sum >= 5) & (neighbor_sum <= 9) & (grid == 1)
    return (born | survive).float()

print("✅ Porous network engine ready!")
np.random.seed(42)
size = 80
grid_np = np.zeros((size, size, size), dtype=np.float32)

for _ in range(220):
    x = np.random.randint(0, size)
    y = np.random.randint(0, size)
    z = np.random.randint(0, size)
    length = np.random.randint(25, 55)
    dx = np.random.randn() * 1.3
    dy = np.random.randn() * 1.3
    dz = np.random.randn() * 1.3
    for i in range(length):
        ix = int(x + i * dx) % size
        iy = int(y + i * dy) % size
        iz = int(z + i * dz) % size
        if 0 <= ix < size and 0 <= iy < size and 0 <= iz < size:
            grid_np[ix, iy, iz] = 1.0

noise = np.random.choice([0, 1], size=(size, size, size), p=[0.85, 0.15])
grid_np = np.clip(grid_np + noise, 0, 1)

grid = torch.from_numpy(grid_np).float().to(device)

# Heat field (temperature)
temperature = torch.zeros((size, size, size), device=device, dtype=torch.float32)
temperature[0:10, 0:10, 0:10] = 1.0  # hot seed in one corner

print(f"Porous network + heat seed initialized — {grid.sum().item():.0f} solid cells")
steps = 3000
density_history = []
temp_history = []

print("Running ULTRA-GENTLE thermal conduction test...")

for step in range(steps):
    grid = poole_manifold_step(grid)
    
    # Ultra-gentle heat diffusion
    empty = (grid < 0.5)
    padded_temp = F.pad(temperature.unsqueeze(0).unsqueeze(0), (1,1,1,1,1,1), mode='circular')
    diffused = F.avg_pool3d(padded_temp, kernel_size=3, stride=1, padding=0).squeeze(0).squeeze(0)
    
    # Very slow decay: heat persists much longer
    temperature = torch.where(empty, diffused * 0.98, diffused * 0.92)
    
    # Tiny background heat maintenance (prevents total collapse)
    temperature += 0.0005
    
    if step % 500 == 0 or step == steps-1:
        density = grid.mean().item()
        avg_temp = temperature.mean().item()
        density_history.append((step, density))
        temp_history.append((step, avg_temp))
        print(f"Step {step:4d} | Density: {density:.4f} | Avg Temperature: {avg_temp:.4f}")
        
        if step % 1000 == 0 or step == steps-1:
            clear_output(wait=True)
            center = size // 2
            fig, axes = plt.subplots(1, 3, figsize=(15,5))
            axes[0].imshow(grid[center].cpu().numpy(), cmap='binary')
            axes[0].set_title('Solid network (XY)')
            axes[1].imshow(temperature[center].cpu().numpy(), cmap='plasma')
            axes[1].set_title('Temperature (XY)')
            axes[2].imshow(temperature[:, center, :].cpu().numpy(), cmap='plasma')
            axes[2].set_title('Temperature (XZ)')
            plt.suptitle(f"Thermal Conduction — Step {step}")
            plt.show()

print("\n✅ ULTRA-GENTLE thermal conduction test finished!")
steps_list, dens_list = zip(*density_history)
t_steps, t_list = zip(*temp_history)

plt.figure(figsize=(10,5))
plt.plot(steps_list, dens_list, 'b-', label='Solid density')
plt.axhline(y=0.31, color='r', linestyle='--', label='Phoenix ~31%')
plt.title('Density during Thermal Conduction')
plt.legend()
plt.grid(True)
plt.show()

plt.figure(figsize=(10,5))
plt.plot(t_steps, t_list, 'orange', label='Average temperature')
plt.title('Heat Spread Over Time')
plt.xlabel('Step')
plt.ylabel('Mean temperature')
plt.legend()
plt.grid(True)
plt.show()

final_grid = grid.cpu().numpy() > 0.5
porosity = 1 - final_grid.mean()
print(f"Porosity: {porosity:.4f} ({porosity*100:.1f}%)")
print(f"Final average temperature: {temperature.mean().item():.4f}")

np.save('thermal_final_grid.npy', final_grid.astype(np.uint8))
np.save('thermal_final_temp.npy', temperature.cpu().numpy())
print("Saved thermal data!")
