import torch
import torch.nn.functional as F
import numpy as np
import matplotlib.pyplot as plt
from IPython.display import clear_output

device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
print(f"Using device: {device} — Optical Light Transport Test online!")
def poole_manifold_step(grid):
    kernel = torch.ones((1, 1, 3, 3, 3), device=device, dtype=torch.float32)
    kernel[0, 0, 1, 1, 1] = 0
    padded = F.pad(grid.unsqueeze(0).unsqueeze(0), (1,1,1,1,1,1), mode='circular')
    neighbor_sum = F.conv3d(padded, kernel, padding=0).squeeze(0).squeeze(0)
    
    born = (neighbor_sum >= 5) & (neighbor_sum <= 7) & (grid == 0)
    survive = (neighbor_sum >= 5) & (neighbor_sum <= 9) & (grid == 1)
    return (born | survive).float()

print("✅ Poole Manifold engine ready!")
np.random.seed(42)
size = 80
grid_np = np.zeros((size, size, size), dtype=np.float32)

# Cosmic web filaments
for _ in range(220):
    x = np.random.randint(0, size)
    y = np.random.randint(0, size)
    z = np.random.randint(0, size)
    length = np.random.randint(25, 55)
    dx = np.random.randn() * 1.3
    dy = np.random.randn() * 1.3
    dz = np.random.randn() * 1.3
    for i in range(length):
        ix = int(x + i * dx) % size
        iy = int(y + i * dy) % size
        iz = int(z + i * dz) % size
        if 0 <= ix < size and 0 <= iy < size and 0 <= iz < size:
            grid_np[ix, iy, iz] = 1.0

noise = np.random.choice([0, 1], size=(size, size, size), p=[0.85, 0.15])
grid_np = np.clip(grid_np + noise, 0, 1)

grid = torch.from_numpy(grid_np).float().to(device)

# Light intensity field
light = torch.zeros((size, size, size), device=device, dtype=torch.float32)

print(f"Porous network initialized — {grid.sum().item():.0f} solid cells")
steps = 3000
density_history = []
light_history = []

print("Running Optical Light Transport Test...")

for step in range(steps):
    grid = poole_manifold_step(grid)
    
    # Light scattering & absorption
    padded_l = F.pad(light.unsqueeze(0).unsqueeze(0), (1,1,1,1,1,1), mode='circular')
    diffused = F.avg_pool3d(padded_l, kernel_size=3, stride=1, padding=0).squeeze(0).squeeze(0)
    
    # Pores = high transmission, filaments = scattering + mild absorption
    pores = (grid < 0.5)
    light = torch.where(pores, diffused * 0.98, diffused * 0.85)
    
    # Light source on left face (continuous for steady-state)
    light[0:5, :, :] = 1.0
    
    if step % 500 == 0 or step == steps-1:
        density = grid.mean().item()
        avg_light = light.mean().item()
        density_history.append((step, density))
        light_history.append((step, avg_light))
        print(f"Step {step:4d} | Density: {density:.4f} | Avg Light Intensity: {avg_light:.4f}")
        
        if step % 1000 == 0 or step == steps-1:
            clear_output(wait=True)
            center = size // 2
            fig, axes = plt.subplots(1, 3, figsize=(15,5))
            axes[0].imshow(grid[center].cpu().numpy(), cmap='binary')
            axes[0].set_title('Solid network (XY)')
            axes[1].imshow(light[center].cpu().numpy(), cmap='plasma')
            axes[1].set_title('Light Intensity (XY)')
            axes[2].imshow(light[:, center, :].cpu().numpy(), cmap='plasma')
            axes[2].set_title('Light Intensity (XZ)')
            plt.suptitle(f"Optical Light Transport — Step {step}")
            plt.show()

print("\n✅ Optical Light Transport test finished!")
steps_list, dens_list = zip(*density_history)
l_steps, l_list = zip(*light_history)

plt.figure(figsize=(10,5))
plt.plot(steps_list, dens_list, 'b-', label='Solid density')
plt.axhline(y=0.31, color='r', linestyle='--', label='Phoenix ~31%')
plt.title('Density during Optical Test')
plt.legend()
plt.grid(True)
plt.show()

plt.figure(figsize=(10,5))
plt.plot(l_steps, l_list, 'yellow', label='Average light intensity')
plt.title('Light Intensity Over Time')
plt.xlabel('Step')
plt.ylabel('Mean intensity')
plt.legend()
plt.grid(True)
plt.show()

final_grid = grid.cpu().numpy() > 0.5
porosity = 1 - final_grid.mean()
print(f"Porosity: {porosity:.4f} ({porosity*100:.1f}%)")
print(f"Final average light intensity: {light.mean().item():.4f}")
print(f"Transmission (right face): {light[-1].mean().item():.4f}")

np.save('optical_final_grid.npy', final_grid.astype(np.uint8))
np.save('optical_final_light.npy', light.cpu().numpy())
print("Saved optical data!")
