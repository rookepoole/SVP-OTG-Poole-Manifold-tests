# ================================================
# PARTICLE SPECTRUM TEST — Complete & Self-Contained
# Tracks stable excitations ("particles") in the Poole Manifold
# ================================================
import torch
import torch.nn.functional as F
import numpy as np
import matplotlib.pyplot as plt
from tqdm import tqdm

device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print(f"Running on: {device}")

# Exact rules from your PDF
PRIMES = [2, 3, 5, 7, 11, 13, 17, 19, 23]
B_LOW, B_HIGH = 5.0, 7.0
S_LOW, S_HIGH = 5.0, 9.0

kernel = torch.ones((1, 1, 3, 3, 3), device=device, dtype=torch.float32)
kernel[0, 0, 1, 1, 1] = 0.0

def run_manifold(field):
    with torch.no_grad():
        padded = F.pad(field.unsqueeze(0).unsqueeze(0), (1,1,1,1,1,1), mode='circular')
        potential = F.conv3d(padded, kernel, padding=0).squeeze(0).squeeze(0)
        resonance = torch.zeros_like(potential)
        for p in PRIMES:
            resonance += 0.35 * torch.exp(-((potential - p)**2) / 0.01)
        total_phi = potential + resonance + 0.12 + 2.0   # persistent amplifier
        birth = (field == 0) & (total_phi >= B_LOW) & (total_phi <= B_HIGH)
        survive = (field == 1) & (total_phi >= S_LOW) & (total_phi <= S_HIGH)
        return (birth | survive).float()

def stamp_macro_orbit(field, center, radius=12):
    x, y, z = torch.meshgrid(torch.arange(field.shape[0], device=device),
                             torch.arange(field.shape[1], device=device),
                             torch.arange(field.shape[2], device=device), indexing='ij')
    r = torch.sqrt((x-center[0])**2 + (y-center[1])**2 + (z-center[2])**2)
    amp_ring = (r >= radius-3) & (r <= radius+3)
    vacuum_eye = (r < radius-7)
    field[amp_ring] = 1.0
    field[vacuum_eye] = 0.0
    return field

# ----------------- Simulation -----------------
GRID_SIZE = 384
field = torch.zeros((GRID_SIZE, GRID_SIZE, GRID_SIZE), device=device, dtype=torch.float32)

# Seed background macro-orbits
for i in range(8):
    cx = np.random.randint(60, GRID_SIZE-60)
    cy = np.random.randint(60, GRID_SIZE-60)
    cz = np.random.randint(40, GRID_SIZE-40)
    field = stamp_macro_orbit(field, (cx, cy, cz), radius=12)

# Add a small localized "particle seed" (Gaussian blob)
x, y, z = torch.meshgrid(torch.arange(GRID_SIZE, device=device),
                         torch.arange(GRID_SIZE, device=device),
                         torch.arange(GRID_SIZE, device=device), indexing='ij')
r = torch.sqrt((x - GRID_SIZE//2)**2 + (y - GRID_SIZE//2)**2 + (z - GRID_SIZE//2 + 40)**2)
field += 0.8 * torch.exp(-r**2 / 12.0)
field = torch.clamp(field, 0.0, 1.0)

print("Initialized background + particle seed")

# Track the excitation
positions = []
velocities = []

for t in tqdm(range(600), desc="Tracking excitations"):
    field = run_manifold(field)
    
    # Center-of-mass of the perturbation (mask near original seed location)
    mask = (x > GRID_SIZE//2 - 60) & (x < GRID_SIZE//2 + 60) & \
           (y > GRID_SIZE//2 - 60) & (y < GRID_SIZE//2 + 60) & \
           (z > GRID_SIZE//2 - 20) & (z < GRID_SIZE//2 + 100)
    mass = field[mask].sum()
    if mass > 1e-4:
        cx = (field[mask] * x[mask]).sum() / mass
        cy = (field[mask] * y[mask]).sum() / mass
        cz = (field[mask] * z[mask]).sum() / mass
        positions.append((cx.item(), cy.item(), cz.item()))
        
        if len(positions) > 1:
            vx = positions[-1][0] - positions[-2][0]
            vy = positions[-1][1] - positions[-2][1]
            vz = positions[-1][2] - positions[-2][2]
            speed = (vx**2 + vy**2 + vz**2)**0.5
            velocities.append(speed)

if velocities:
    print(f"\n✅ Excitation tracking complete")
    print(f"Average speed          = {np.mean(velocities):.4f} cells/step")
    print(f"Speed dispersion       = {np.std(velocities):.4f}")
    print(f"Number of tracked steps = {len(velocities)}")
else:
    print("No stable excitation detected — try adjusting seed amplitude or radius.")

# Simple velocity plot
if velocities:
    plt.figure(figsize=(10, 5))
    plt.plot(velocities, 'b-', label='Instantaneous speed')
    plt.axhline(np.mean(velocities), color='red', linestyle='--', label='Average speed')
    plt.xlabel('Time step')
    plt.ylabel('Speed (cells/step)')
    plt.title('Particle-like Excitation Velocity')
    plt.legend()
    plt.grid(True)
    plt.show()
