import torch
import torch.nn.functional as F
import numpy as np
import matplotlib.pyplot as plt
from scipy import ndimage
import scipy.ndimage as ndi
from IPython.display import clear_output

device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
print(f"Using device: {device} —  online!")
def poole_manifold_step(grid):
    kernel = torch.ones((1, 1, 3, 3, 3), device=device, dtype=torch.float32)
    kernel[0, 0, 1, 1, 1] = 0
    padded = F.pad(grid.unsqueeze(0).unsqueeze(0), (1,1,1,1,1,1), mode='circular')
    neighbor_sum = F.conv3d(padded, kernel, padding=0).squeeze(0).squeeze(0)
    
    born = (neighbor_sum >= 5) & (neighbor_sum <= 7) & (grid == 0)
    survive = (neighbor_sum >= 5) & (neighbor_sum <= 9) & (grid == 1)
    return (born | survive).float()

print("✅ Plain cosmic-web engine ready!")
np.random.seed(42)
size = 80
grid_np = np.zeros((size, size, size), dtype=np.float32)

for _ in range(220):
    x = np.random.randint(0, size)
    y = np.random.randint(0, size)
    z = np.random.randint(0, size)
    length = np.random.randint(25, 55)
    dx = np.random.randn() * 1.3
    dy = np.random.randn() * 1.3
    dz = np.random.randn() * 1.3
    for i in range(length):
        ix = int(x + i * dx) % size
        iy = int(y + i * dy) % size
        iz = int(z + i * dz) % size
        if 0 <= ix < size and 0 <= iy < size and 0 <= iz < size:
            grid_np[ix, iy, iz] = 1.0
            if i % 3 == 0:
                grid_np[(ix+1)%size, iy, iz] = 1.0

noise = np.random.choice([0, 1], size=(size, size, size), p=[0.85, 0.15])
grid_np = np.clip(grid_np + noise, 0, 1)

grid = torch.from_numpy(grid_np).float().to(device)
print(f"Cosmic web initialized — {grid.sum().item():.0f} live cells")
steps = 5000
density_history = []

print("Running cosmic-web simulation for real-world stats...")

for step in range(steps):
    grid = poole_manifold_step(grid)
    
    if step % 500 == 0 or step == steps-1:
        density = grid.mean().item()
        density_history.append((step, density))
        print(f"Step {step:4d} | Density: {density:.4f}")

# Convert to numpy for analysis
final_grid = grid.cpu().numpy() > 0.5  # binary

# Save point cloud (only live cells)
points = np.argwhere(final_grid)
np.save('poole_manifold_points.npy', points)
np.savetxt('poole_manifold_points.csv', points, delimiter=',', header='x,y,z', comments='')

print(f"\n✅ Saved {len(points)} live cells as point cloud")
# Fractal dimension (box-counting)
def fractal_dimension(grid, max_box=20):
    dims = np.array(grid.shape)
    scales = 2**np.arange(1, int(np.log2(max_box))+1)
    counts = []
    for scale in scales:
        shape = dims // scale
        blocks = grid.reshape(shape[0], scale, shape[1], scale, shape[2], scale).any(axis=(1,3,5))
        counts.append(blocks.sum())
    scales_log = np.log(1/scales)
    counts_log = np.log(counts)
    slope, _ = np.polyfit(scales_log, counts_log, 1)
    return slope

fd = fractal_dimension(final_grid)
print(f"Fractal dimension (box-counting): {fd:.3f}")

# Pore size distribution (distance transform on empty space)
empty = ~final_grid
dist = ndi.distance_transform_edt(empty)
pore_sizes = dist[empty]
hist, bin_edges = np.histogram(pore_sizes, bins=30, range=(0, 15))
print(f"Average pore radius: {pore_sizes.mean():.2f} voxels")
print(f"Max pore radius: {pore_sizes.max():.2f} voxels")

# Connectivity
labeled, num_features = ndi.label(final_grid)
sizes = np.bincount(labeled.ravel())[1:]
print(f"Number of separate filament clusters: {num_features}")
print(f"Average cluster size: {sizes.mean():.1f} cells")
print(f"Largest cluster: {sizes.max():.0f} cells")

# Quick density check
print(f"Final density: {final_grid.mean():.4f}")
