import torch
import torch.nn.functional as F
import matplotlib.pyplot as plt
import numpy as np

# Check if running in Google Colab to trigger automatic download
try:
    from google.colab import files
    IN_COLAB = True
except ImportError:
    IN_COLAB = False

# Hardware instantiation
device = torch.device("cuda" if torch.cuda.is_available() else "cpu")

# Thermodynamic Boundaries
B_LOW, B_HIGH = 5.0, 7.0
S_LOW, S_HIGH = 5.0, 9.0
PRIMES = [2, 3, 5, 7, 11, 13, 17, 19, 23]

# The Spherical Convolution Kernel
kernel = torch.ones((1, 1, 3, 3, 3), device=device).float()
kernel[0, 0, 1, 1, 1] = 0.0

def run_manifold_batch(f, amp_mask):
    """Executes 1 tick of the OTG tensor physics across a batch of parallel universes."""
    with torch.no_grad():
        f_float = f.float()
        
        # Periodic (toroidal) boundary conditions
        padded = F.pad(f_float, (1, 1, 1, 1, 1, 1), mode='circular')
        
        # Calculate base neighborhood pressure
        potential = F.conv3d(padded, kernel, padding=0)
        
        # Apply the amplifier mask (simulating the localized +1.0 potential field)
        potential = torch.where(amp_mask, potential + 1.0, potential)
        
        # Prime-Resonance Sharpening
        resonance = torch.zeros_like(potential)
        for p in PRIMES:
            resonance += 0.35 * torch.exp(-((potential - p)**2) / 0.01)
            
        total_phi = potential + resonance
        
        # Survival/Birth Logic
        birth = (f == 0) & (total_phi >= B_LOW) & (total_phi <= B_HIGH)
        survive = (f == 1) & (total_phi >= S_LOW) & (total_phi <= S_HIGH)
        
        return (birth | survive).float()

# --- DISCOVERY ENGINE SETUP ---
BATCH_SIZE = 64  # Run 64 parallel universes at once
GRID_SIZE = 32   # Small 32x32 bounding box for each particle
GRID_Z = 10
TOTAL_FRAMES = 150

# Initialize 64 empty parallel grids
fields = torch.zeros((BATCH_SIZE, 1, GRID_SIZE, GRID_SIZE, GRID_Z), device=device)
amp_masks = torch.zeros_like(fields).bool()

print(f"Generating {BATCH_SIZE} random topological seeds...")

# Inject a random 12x12 "primordial soup" seed into the center of each universe
for i in range(BATCH_SIZE):
    # Create a random binary mask for the core shape
    seed_shape = (torch.rand((12, 12, 5), device=device) > 0.6).float()
    
    # Stamp the seed into the center of the grid
    cy, cx = GRID_SIZE // 2, GRID_SIZE // 2
    fields[i, 0, cy-6:cy+6, cx-6:cx+6, 2:7] = seed_shape
    
    # Give the core structure thermodynamic armor (Amplifier Mask) so it has a chance to survive
    amp_masks[i, 0, cy-8:cy+8, cx-8:cx+8, 2:7] = True

print(f"Executing {TOTAL_FRAMES} frames of thermodynamic selection...")

# Run the physics engine across all 64 universes simultaneously
for t in range(TOTAL_FRAMES):
    # Enforce static structural bounds for the armor
    fields = torch.where(amp_masks, fields, fields)
    
    # Execute batch physics
    fields = run_manifold_batch(fields, amp_masks)

print("Selection phase complete. Scanning for survivors...")

# --- DATA FILTERING & OUTPUT ---
survivors = []
for i in range(BATCH_SIZE):
    final_mass = fields[i].sum().item()
    if final_mass > 0:
        survivors.append((i, final_mass, fields[i, 0, :, :, :].sum(dim=-1).cpu().numpy()))

print(f"\n--- DISCOVERY REPORT ---")
print(f"Total Seeds Tested: {BATCH_SIZE}")
print(f"Evaporated/Blown Out: {BATCH_SIZE - len(survivors)}")
print(f"Immortal Structures Found: {len(survivors)}")

# Plot the survivors
if len(survivors) > 0:
    # Limit plot to a maximum of 16 survivors for visual clarity
    plot_count = min(len(survivors), 16)
    cols = 4
    rows = (plot_count + cols - 1) // cols
    
    fig, axes = plt.subplots(rows, cols, figsize=(15, 4 * rows), facecolor='#0f0f0f')
    fig.patch.set_facecolor('#0f0f0f')
    
    # Handle single row case for axes indexing
    if rows == 1:
        axes = [axes]
        
    for idx in range(plot_count):
        r, c = idx // cols, idx % cols
        ax = axes[r][c] if rows > 1 else axes[c]
        
        batch_id, mass, frame_data = survivors[idx]
        
        ax.imshow(frame_data, cmap='magma', origin='upper')
        ax.set_title(f"Seed ID: {batch_id}\nStable Mass: {mass:,.0f}", color='white', fontsize=10)
        ax.axis('off')
        
    # Turn off any unused subplots
    for idx in range(plot_count, rows * cols):
        r, c = idx // cols, idx % cols
        ax = axes[r][c] if rows > 1 else axes[c]
        ax.axis('off')

    plt.suptitle("Poole Manifold: Automated Particle Discovery\n(Surviving Topologies at T=150)", color='white', fontsize=16, y=1.02)
    plt.tight_layout()
    plt.savefig("particle_discovery_results.png", facecolor='#0f0f0f')
    plt.show()
    
    if IN_COLAB:
        files.download("particle_discovery_results.png")
else:
    print("\nNo stable structures survived the thermodynamic selection. All seeds flash-evaporated or popped.")
    print("Recommendation: Adjust the seed density or amplifier mask size and run again.")
