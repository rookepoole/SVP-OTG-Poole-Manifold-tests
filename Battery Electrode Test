import torch
import torch.nn.functional as F
import numpy as np
import matplotlib.pyplot as plt
from IPython.display import clear_output
import time

device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
print(f"Using device: {device} — Battery Electrode Engine Ready!")

size = 80

def poole_manifold_step(grid):
    kernel = torch.ones((1, 1, 3, 3, 3), device=device, dtype=torch.float32)
    kernel[0, 0, 1, 1, 1] = 0
    padded = F.pad(grid.unsqueeze(0).unsqueeze(0), (1,1,1,1,1,1), mode='circular')
    neighbor_sum = F.conv3d(padded, kernel, padding=0).squeeze(0).squeeze(0)
    born = (neighbor_sum >= 5) & (neighbor_sum <= 7) & (grid == 0)
    survive = (neighbor_sum >= 5) & (neighbor_sum <= 9) & (grid == 1)
    return (born | survive).float()
    torch.manual_seed(42)
np.random.seed(42)
grid = torch.zeros((size, size, size), device=device, dtype=torch.float32)

for _ in range(220):
    x0 = np.random.randint(0, size)
    y0 = np.random.randint(0, size)
    z0 = np.random.randint(0, size)
    length = np.random.randint(25, 55)
    dx = np.random.choice([-1, 1])
    dy = np.random.choice([-1, 1])
    dz = np.random.choice([-1, 1])
    for i in range(length):
        x = (x0 + i * dx) % size
        y = (y0 + i * dy) % size
        z = (z0 + i * dz) % size
        grid[x, y, z] = 1.0

noise = (torch.rand(size, size, size, device=device) < 0.15).float()
grid = torch.clamp(grid + noise, 0, 1)

print(f"Initial grid ready — {int(grid.sum().item())} live cells")
# Two fields: voltage (fast conductor) + ion concentration (slower transport)
voltage = torch.zeros((size, size, size), device=device, dtype=torch.float32)
ions = torch.zeros((size, size, size), device=device, dtype=torch.float32)

# Seed ions in left-face pores (like electrolyte injection)
for x in range(12):
    for y in range(size):
        for z in range(size):
            if grid[x, y, z] < 0.5:
                ions[x, y, z] = 1.0
                voltage[x, y, z] = 1.0  # initial charge

print("Ion + voltage fields seeded — Battery Electrode ready")
steps = 4000
density_history = []
ion_history = []
voltage_history = []
capacity_history = []

print("Running FIXED Battery Electrode / Ion Transport Test (gentler + stronger pulses)...\n")

for step in range(steps):
    grid = poole_manifold_step(grid)
    
    # Voltage diffusion — much gentler (same pattern that fixed drug release)
    padded_v = F.pad(voltage.unsqueeze(0).unsqueeze(0), (1,1,1,1,1,1), mode='circular')
    diffused_v = F.avg_pool3d(padded_v, kernel_size=3, stride=1, padding=0).squeeze(0).squeeze(0)
    pores = (grid < 0.5)
    voltage = torch.where(pores, diffused_v * 0.992, diffused_v * 0.975)
    voltage += 0.00015   # tiny background maintenance
    
    # Ion transport — slower and more stable
    padded_i = F.pad(ions.unsqueeze(0).unsqueeze(0), (1,1,1,1,1,1), mode='circular')
    diffused_i = F.avg_pool3d(padded_i, kernel_size=3, stride=1, padding=0).squeeze(0).squeeze(0)
    ions = torch.where(pores, diffused_i * 0.988, diffused_i * 0.965)
    ions += 0.00012
    
    # Stronger and more frequent charging pulses (every 600 steps)
    if step % 600 == 0:
        voltage[0:10, :, :] = 1.0
        ions[0:10, :, :] = 1.0
    
    # Metrics
    density = grid.mean().item()
    avg_ions = ions.mean().item()
    avg_voltage = voltage.mean().item()
    capacity = avg_ions * avg_voltage
    
    density_history.append(density)
    ion_history.append(avg_ions)
    voltage_history.append(avg_voltage)
    capacity_history.append(capacity)
    
    if step % 500 == 0 or step == steps - 1:
        clear_output(wait=True)
        print(f"Step {step:4d} | Density: {density:.4f} | Avg Ions: {avg_ions:.4f} | Avg Voltage: {avg_voltage:.4f} | Capacity: {capacity:.4f}")
        
        center = size // 2
        fig, axes = plt.subplots(1, 3, figsize=(18, 5))
        axes[0].imshow(grid[center].cpu().numpy(), cmap='binary')
        axes[0].set_title('Solid Network (XY)')
        axes[1].imshow(ions[center].cpu().numpy(), cmap='plasma')
        axes[1].set_title('Ion Concentration (XY)')
        axes[2].imshow(voltage[:, center, :].cpu().numpy(), cmap='plasma')
        axes[2].set_title('Voltage (XZ)')
        plt.suptitle(f'FIXED Battery Electrode Test — Step {step}')
        plt.show()

print(f"\n✅ FIXED Battery Electrode Test finished!")
print(f"Final porosity: {1-grid.mean().item():.4f} ({(1-grid.mean().item())*100:.1f}%)")
print(f"Final capacity: {capacity_history[-1]:.4f}")
np.save('battery_final_grid.npy', grid.cpu().numpy())
np.save('battery_final_ions.npy', ions.cpu().numpy())
np.save('battery_final_voltage.npy', voltage.cpu().numpy())
