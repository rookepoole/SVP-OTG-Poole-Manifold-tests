import torch
import torch.nn.functional as F
import numpy as np
import matplotlib.pyplot as plt
from IPython.display import clear_output

device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
print(f"Using device: {device} — Reaction-Diffusion (Gray-Scott) Test online!")
def poole_manifold_step(grid):
    kernel = torch.ones((1, 1, 3, 3, 3), device=device, dtype=torch.float32)
    kernel[0, 0, 1, 1, 1] = 0
    padded = F.pad(grid.unsqueeze(0).unsqueeze(0), (1,1,1,1,1,1), mode='circular')
    neighbor_sum = F.conv3d(padded, kernel, padding=0).squeeze(0).squeeze(0)
    
    born = (neighbor_sum >= 5) & (neighbor_sum <= 7) & (grid == 0)
    survive = (neighbor_sum >= 5) & (neighbor_sum <= 9) & (grid == 1)
    return (born | survive).float()

print("✅ Poole Manifold engine ready!")
np.random.seed(42)
size = 80
grid_np = np.zeros((size, size, size), dtype=np.float32)

# Cosmic web filaments
for _ in range(220):
    x = np.random.randint(0, size)
    y = np.random.randint(0, size)
    z = np.random.randint(0, size)
    length = np.random.randint(25, 55)
    dx = np.random.randn() * 1.3
    dy = np.random.randn() * 1.3
    dz = np.random.randn() * 1.3
    for i in range(length):
        ix = int(x + i * dx) % size
        iy = int(y + i * dy) % size
        iz = int(z + i * dz) % size
        if 0 <= ix < size and 0 <= iy < size and 0 <= iz < size:
            grid_np[ix, iy, iz] = 1.0

noise = np.random.choice([0, 1], size=(size, size, size), p=[0.85, 0.15])
grid_np = np.clip(grid_np + noise, 0, 1)

grid = torch.from_numpy(grid_np).float().to(device)

# Gray-Scott chemicals: U (substrate) and V (reactant)
U = torch.ones((size, size, size), device=device, dtype=torch.float32)
V = torch.zeros((size, size, size), device=device, dtype=torch.float32)

# Seed a small reaction spot in the center
center = size // 2
U[center-8:center+8, center-8:center+8, center-8:center+8] = 0.5
V[center-8:center+8, center-8:center+8, center-8:center+8] = 1.0

print(f"Porous network + chemical seed initialized — {grid.sum().item():.0f} solid cells")
steps = 3000
density_history = []
pattern_history = []

print("Running Reaction-Diffusion (Gray-Scott) Test...")

for step in range(steps):
    grid = poole_manifold_step(grid)
    
    # Gray-Scott reaction-diffusion step
    padded_U = F.pad(U.unsqueeze(0).unsqueeze(0), (1,1,1,1,1,1), mode='circular')
    padded_V = F.pad(V.unsqueeze(0).unsqueeze(0), (1,1,1,1,1,1), mode='circular')
    
    lap_U = F.avg_pool3d(padded_U, 3, stride=1, padding=0).squeeze(0).squeeze(0) - U
    lap_V = F.avg_pool3d(padded_V, 3, stride=1, padding=0).squeeze(0).squeeze(0) - V
    
    # Classic Gray-Scott parameters (produces nice spots/mazes)
    F_rate = 0.035
    k_rate = 0.065
    diff_U = 0.16
    diff_V = 0.08
    
    reaction = U * V * V
    dU = diff_U * lap_U - reaction + F_rate * (1 - U)
    dV = diff_V * lap_V + reaction - (F_rate + k_rate) * V
    
    # Filaments slightly inhibit reaction (realistic catalyst/barrier effect)
    pores = (grid < 0.5)
    dU = torch.where(pores, dU, dU * 0.85)
    dV = torch.where(pores, dV, dV * 0.85)
    
    U = torch.clamp(U + dU, 0, 1)
    V = torch.clamp(V + dV, 0, 1)
    
    if step % 500 == 0 or step == steps-1:
        density = grid.mean().item()
        avg_V = V.mean().item()
        density_history.append((step, density))
        pattern_history.append((step, avg_V))
        print(f"Step {step:4d} | Density: {density:.4f} | Avg Reactant (V): {avg_V:.4f}")
        
        if step % 1000 == 0 or step == steps-1:
            clear_output(wait=True)
            center = size // 2
            fig, axes = plt.subplots(1, 3, figsize=(15,5))
            axes[0].imshow(grid[center].cpu().numpy(), cmap='binary')
            axes[0].set_title('Solid network (XY)')
            axes[1].imshow(V[center].cpu().numpy(), cmap='plasma')
            axes[1].set_title('Reactant V (XY)')
            axes[2].imshow(V[:, center, :].cpu().numpy(), cmap='plasma')
            axes[2].set_title('Reactant V (XZ)')
            plt.suptitle(f"Reaction-Diffusion — Step {step}")
            plt.show()

print("\n✅ Reaction-Diffusion test finished!")
steps_list, dens_list = zip(*density_history)
v_steps, v_list = zip(*pattern_history)

plt.figure(figsize=(10,5))
plt.plot(steps_list, dens_list, 'b-', label='Solid density')
plt.axhline(y=0.31, color='r', linestyle='--', label='Phoenix ~31%')
plt.title('Density during Reaction-Diffusion')
plt.legend()
plt.grid(True)
plt.show()

plt.figure(figsize=(10,5))
plt.plot(v_steps, v_list, 'magenta', label='Average Reactant V')
plt.title('Reaction Pattern Intensity Over Time')
plt.xlabel('Step')
plt.ylabel('Mean V concentration')
plt.legend()
plt.grid(True)
plt.show()

final_grid = grid.cpu().numpy() > 0.5
porosity = 1 - final_grid.mean()
print(f"Porosity: {porosity:.4f} ({porosity*100:.1f}%)")
print(f"Final average reactant concentration: {V.mean().item():.4f}")

np.save('reaction_final_grid.npy', final_grid.astype(np.uint8))
np.save('reaction_final_V.npy', V.cpu().numpy())
print("Saved reaction-diffusion data!")
