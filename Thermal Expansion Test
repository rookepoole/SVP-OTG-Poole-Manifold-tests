import torch
import torch.nn.functional as F
import numpy as np
import matplotlib.pyplot as plt
from IPython.display import clear_output
import time

device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
print(f"Using device: {device} — Thermal Expansion Engine Ready!")

size = 80

def poole_manifold_step(grid):
    kernel = torch.ones((1, 1, 3, 3, 3), device=device, dtype=torch.float32)
    kernel[0, 0, 1, 1, 1] = 0
    padded = F.pad(grid.unsqueeze(0).unsqueeze(0), (1,1,1,1,1,1), mode='circular')
    neighbor_sum = F.conv3d(padded, kernel, padding=0).squeeze(0).squeeze(0)
    born = (neighbor_sum >= 5) & (neighbor_sum <= 7) & (grid == 0)
    survive = (neighbor_sum >= 5) & (neighbor_sum <= 9) & (grid == 1)
    return (born | survive).float()
    torch.manual_seed(42)
np.random.seed(42)
grid = torch.zeros((size, size, size), device=device, dtype=torch.float32)

for _ in range(220):
    x0 = np.random.randint(0, size)
    y0 = np.random.randint(0, size)
    z0 = np.random.randint(0, size)
    length = np.random.randint(25, 55)
    dx = np.random.choice([-1, 1])
    dy = np.random.choice([-1, 1])
    dz = np.random.choice([-1, 1])
    for i in range(length):
        x = (x0 + i * dx) % size
        y = (y0 + i * dy) % size
        z = (z0 + i * dz) % size
        grid[x, y, z] = 1.0

noise = (torch.rand(size, size, size, device=device) < 0.15).float()
grid = torch.clamp(grid + noise, 0, 1)

print(f"Initial grid ready — {int(grid.sum().item())} live cells")
temperature = torch.zeros((size, size, size), device=device, dtype=torch.float32)

# Seed heat on left face (realistic thermal gradient)
temperature[:12, :, :] = 1.0

print("Thermal gradient seeded — Expansion test ready")
steps = 4000
density_history = []
temp_history = []
broken_history = []

print("Running Thermal Expansion & Thermo-Mechanical Stress Test...\n")

for step in range(steps):
    grid = poole_manifold_step(grid)
    
    # Thermal diffusion (gentle, as in previous thermal test)
    padded_t = F.pad(temperature.unsqueeze(0).unsqueeze(0), (1,1,1,1,1,1), mode='circular')
    diffused = F.avg_pool3d(padded_t, kernel_size=3, stride=1, padding=0).squeeze(0).squeeze(0)
    pores = (grid < 0.5)
    temperature = torch.where(pores, diffused * 0.99, diffused * 0.96)
    temperature += 0.0001  # maintenance
    
    # Thermal expansion: hot filaments slightly "grow" (local density increase)
    hot_mask = (temperature > 0.4) & (~pores)
    grid[hot_mask] = torch.clamp(grid[hot_mask] + 0.08, 0.0, 1.0)
    
    # Count broken cells due to expansion stress
    broken = (grid < 0.3).sum().item() / (size**3) * 100  # % of network stressed/broken
    
    # Metrics
    density = grid.mean().item()
    avg_temp = temperature.mean().item()
    
    density_history.append(density)
    temp_history.append(avg_temp)
    broken_history.append(broken)
    
    if step % 500 == 0 or step == steps - 1:
        clear_output(wait=True)
        print(f"Step {step:4d} | Density: {density:.4f} | Avg Temp: {avg_temp:.4f} | Broken/Stress: {broken:.2f}%")
        
        center = size // 2
        fig, axes = plt.subplots(1, 3, figsize=(18, 5))
        axes[0].imshow(grid[center].cpu().numpy(), cmap='binary')
        axes[0].set_title('Solid Network (XY)')
        axes[1].imshow(temperature[center].cpu().numpy(), cmap='plasma')
        axes[1].set_title('Temperature (XY)')
        axes[2].imshow(temperature[:, center, :].cpu().numpy(), cmap='plasma')
        axes[2].set_title('Temperature (XZ)')
        plt.suptitle(f'Thermal Expansion Test — Step {step} | Stress: {broken:.2f}%')
        plt.show()

print(f"\n✅ Thermal Expansion Test finished!")
print(f"Final porosity: {1-grid.mean().item():.4f} ({(1-grid.mean().item())*100:.1f}%)")
print(f"Final induced stress (broken fraction): {broken_history[-1]:.2f}%")
np.save('thermal_expansion_final_grid.npy', grid.cpu().numpy())
np.save('thermal_expansion_final_temp.npy', temperature.cpu().numpy())
