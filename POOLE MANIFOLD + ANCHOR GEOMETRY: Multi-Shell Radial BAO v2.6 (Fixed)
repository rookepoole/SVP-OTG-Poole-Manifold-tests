import torch
import numpy as np
import healpy as hp
import matplotlib.pyplot as plt
from mpl_toolkits.mplot3d import Axes3D

device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print(f"🚀 Running on: {device}")

# === ATOMIC SPECIES ===
atomic_species = "H"        # "He", "H", or "naked"
print(f"🔬 Atomic species: {atomic_species.upper()}")

# === PARAMETERS ===
N = 120
CENTER = N // 2

orthogon_strength = 1.74
flow_freq = 0.22

tricyl_center = 0.62
r_planar = 1.5
sigma_p = 0.30
r_covalent = 0.707
decay_rate = 0.00060

# Species-specific
if atomic_species == "He":
    tricyl_weight = 0.54
    monopole_weight = 1.28
    w_p = 0.72
    w_c = 2.65
    sigma_c = 0.17
    beta_asym = 0.345
elif atomic_species == "H":
    tricyl_weight = 0.39
    monopole_weight = 1.08
    w_p = 0.92
    w_c = 2.1
    sigma_c = 0.23
    beta_asym = 0.32
else:  # naked
    tricyl_weight = 0.07
    monopole_weight = 0.52
    w_p = 1.15
    w_c = 1.15
    sigma_c = 0.37
    beta_asym = 0.29

# --- GRID ---
X, Y, Z = torch.meshgrid(
    torch.arange(N, device=device, dtype=torch.float32),
    torch.arange(N, device=device, dtype=torch.float32),
    torch.arange(N, device=device, dtype=torch.float32),
    indexing='ij'
)
rx = X - CENTER
ry = Y - CENTER
rz = Z - CENTER
R = torch.sqrt(rx**2 + ry**2 + rz**2) + 1e-6

# --- CORE RULES ---
flow = (torch.sin(flow_freq * rx) * torch.cos(flow_freq * ry) +
        torch.cos(flow_freq * ry) * torch.sin(flow_freq * rz) +
        torch.sin(flow_freq * rz) * torch.cos(flow_freq * rx)) * orthogon_strength

cyl = torch.min(torch.abs(rx), torch.min(torch.abs(ry), torch.abs(rz)))
tricyl = torch.exp(-10.0 * (cyl - tricyl_center)**2) * tricyl_weight

planar = torch.zeros_like(R)
for sign in [-1.0, 1.0]:
    planar += torch.exp( -((rx - sign * r_planar)**2 + ry**2 + rz**2) / sigma_p**2 )
    planar += torch.exp( -((rx)**2 + (ry - sign * r_planar)**2 + rz**2) / sigma_p**2 )
    planar += torch.exp( -((rx)**2 + ry**2 + (rz - sign * r_planar)**2) / sigma_p**2 )

covalent = torch.zeros_like(R)
for sx in [-1.0, 1.0]:
    for sy in [-1.0, 1.0]:
        for sz in [-1.0, 1.0]:
            covalent += torch.exp( -((rx - sx*r_covalent)**2 + 
                                     (ry - sy*r_covalent)**2 + 
                                     (rz - sz*r_covalent)**2) / sigma_c**2 )

monopole_spark = w_p * planar + w_c * covalent

u = flow + beta_asym * torch.sin(0.15 * R) + tricyl + monopole_weight * monopole_spark
u = u * torch.exp(-decay_rate * R)
u = u * (1.0 - 0.03 * torch.sigmoid((R - 25.0)/8.0))

perp_bias = 0.22 * (torch.abs(rx*ry) + torch.abs(ry*rz) + torch.abs(rz*rx)) / (R + 1e-6)
u += perp_bias
u = torch.tanh(u)

# --- MULTI-SHELL ANALYSIS ---
shell_radii = [28.0, 34.0, 40.0]
NSIDE = 64
results = {}

plt.style.use('dark_background')
fig = plt.figure(figsize=(18, 12))

for i, rad in enumerate(shell_radii):
    shell_mask = (R > rad - 2.0) & (R < rad + 2.0)
    x_s = rx[shell_mask].cpu().numpy()
    y_s = ry[shell_mask].cpu().numpy()
    z_s = rz[shell_mask].cpu().numpy()
    u_s = u[shell_mask].cpu().numpy()

    r_norm = np.sqrt(x_s**2 + y_s**2 + z_s**2) + 1e-8
    x_s /= r_norm
    y_s /= r_norm
    z_s /= r_norm

    theta = np.arccos(np.clip(z_s, -1.0, 1.0))
    phi = np.arctan2(y_s, x_s)

    NPIX = hp.nside2npix(NSIDE)
    hpx = np.zeros(NPIX)
    pix = hp.ang2pix(NSIDE, theta, phi)
    np.add.at(hpx, pix, u_s)
    hpx /= np.max(np.abs(hpx)) + 1e-8

    cl = hp.anafast(hpx)
    ell = np.arange(len(cl))

    results[rad] = {'cl': cl, 'map': hpx}

    # Angular C_ℓ
    ax = fig.add_subplot(3, 2, 2*i + 1)
    ax.plot(ell, cl, color='cyan', linewidth=1.8)
    ax.axvline(x=3, color='magenta', linestyle='--', alpha=0.7)
    ax.set_title(f'Angular C_ℓ @ r = {rad}', fontsize=12)
    ax.set_yscale('log')
    ax.grid(True, alpha=0.3)

# 3D Knot
ax3d = fig.add_subplot(3, 2, 2, projection='3d')
high_mask = (u > 0.5 * u.max())
ax3d.scatter(rx[high_mask].cpu().numpy(), 
             ry[high_mask].cpu().numpy(), 
             rz[high_mask].cpu().numpy(),
             c=u[high_mask].cpu().numpy(), 
             cmap='plasma', s=1.2, alpha=0.7)
ax3d.set_title('3D Knot + Monopole Peaks')

# Central Slice
ax_slice = fig.add_subplot(3, 2, 4)
im = ax_slice.imshow(u[:,:,CENTER].cpu().numpy(), cmap='viridis', origin='lower')
ax_slice.set_title('Central Slice')
plt.colorbar(im, ax=ax_slice)

plt.tight_layout()
plt.show()

# Separate Sky Maps
for rad in shell_radii:
    plt.figure(figsize=(10, 6))
    hp.mollview(results[rad]['map'], cmap='plasma', 
                title=f"OTG Sky @ r = {rad} ({atomic_species} nucleus)", 
                min=-1, max=1, hold=True)
    plt.show()

print("✅ Multi-shell radial BAO analysis complete!")
