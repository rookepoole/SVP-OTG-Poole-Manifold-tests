import torch
import torch.nn.functional as F
import matplotlib.pyplot as plt
import numpy as np

print("Initializing Poole Manifold: Full Orbital Distance Sweep...")

device = torch.device("cuda" if torch.cuda.is_available() else "cpu")

SIZE = 64
STEPS = 60
kernel = torch.ones((1, 1, 3, 3, 3), dtype=torch.float32, device=device)
kernel[0, 0, 1, 1, 1] = 0.0  

prime_sequence = [2, 3, 5, 7, 11, 13, 17, 19, 23]
ALPHA = 0.35
SIGMA_SQ = 0.001  # Tight halo, sterile vacuum

# The locked star
mask = torch.zeros((1, 1, SIZE, SIZE, SIZE), dtype=torch.float32, device=device)
center_idx = SIZE // 2
star_radius = 4

z, y, x = torch.meshgrid(torch.arange(SIZE), torch.arange(SIZE), torch.arange(SIZE), indexing='ij')
dist_from_center = torch.sqrt((x - center_idx)**2 + (y - center_idx)**2 + (z - center_idx)**2)
mask[0, 0, dist_from_center <= star_radius] = 1.0  

# Distances to test (Y-coordinates for the photon beam)
injection_distances = list(range(8, 27))
deflection_results = []

for start_y in injection_distances:
    grid = torch.zeros((1, 1, SIZE, SIZE, SIZE), dtype=torch.float32, device=device)
    grid[mask == 1.0] = 1.0 
    
    trajectory_y = []
    
    for step in range(STEPS):
        # Inject kinetic packet
        beam_z = center_idx
        beam_x_start = step      
        
        if beam_x_start < SIZE - 5:
            grid[0, 0, beam_z-1:beam_z+1, start_y-1:start_y+1, beam_x_start:beam_x_start+2] = 1.0

        conv = F.conv3d(grid, kernel, padding=1)
        
        resonance = torch.zeros_like(conv)
        for p in prime_sequence:
            resonance += ALPHA * torch.exp(-((conv - p)**2) / SIGMA_SQ)
        
        resonance = resonance * grid
        phi_total = conv + mask + resonance 

        survives = (grid == 1.0) & (phi_total >= 5) & (phi_total <= 9)
        is_born = (grid == 0.0) & (phi_total >= 5) & (phi_total <= 7)
        
        new_grid = (survives | is_born).float()
        new_grid[mask == 1.0] = 1.0 # Lock star
        grid = new_grid
        
        # Isolated Telemetry (Blind sensor to the star and its corona)
        beam_only = grid.clone()
        beam_only[:, :, :, 28:, :] = 0.0 
        
        active_indices = torch.nonzero(beam_only[0, 0])
        if len(active_indices) > 0:
            cz, cy, cx = active_indices.float().mean(dim=0)
            trajectory_y.append(cy.item())
            
    if len(trajectory_y) > 0:
        net_deflection = trajectory_y[-1] - trajectory_y[0]
        deflection_results.append(net_deflection)
    else:
        deflection_results.append(None) # Evaporated

print("\n--- SWEEP COMPLETE ---")

# Visualization
valid_distances = []
valid_deflections = []

for d, defl in zip(injection_distances, deflection_results):
    if defl is not None:
        valid_distances.append(d)
        valid_deflections.append(defl)
        status = "ATTRACTION" if defl > 0 else "REPULSION" if defl < -0.1 else "NEUTRAL"
        print(f"Injection Y: {d:2d} | Net Deflection: {defl:>6.2f} voxels | {status}")
    else:
        print(f"Injection Y: {d:2d} | FLASH EVAPORATED")

fig, ax = plt.subplots(figsize=(10, 6))
ax.plot(valid_distances, valid_deflections, marker='o', color='purple', linewidth=2)
ax.axhline(y=0, color='gray', linestyle='--', label='Zero Deflection (Straight Path)')
ax.fill_between(valid_distances, 0, valid_deflections, where=(np.array(valid_deflections) > 0), color='green', alpha=0.3, label='Attraction Zone')
ax.fill_between(valid_distances, 0, valid_deflections, where=(np.array(valid_deflections) < 0), color='red', alpha=0.3, label='Repulsion Zone')

ax.set_xlabel('Injection Distance from Star (Y-Coordinate)')
ax.set_ylabel('Net Deflection (Voxels)')
ax.set_title('Topological Deflection vs. Orbital Distance')
ax.invert_xaxis() # Star is at Y=32, so moving left to right means getting further away
ax.legend()
ax.grid(True, linestyle='--', alpha=0.6)

plt.show()
