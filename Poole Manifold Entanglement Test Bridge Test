import torch
import numpy as np
import matplotlib.pyplot as plt

device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print(f"🚀 Running Poole Manifold Entanglement Test on: {device}")

# --- Poole Engine ---
B_LOW, B_HIGH = 5.0, 7.0
S_LOW, S_HIGH = 5.0, 9.0
GRID_SIZE = 256
PRIMES = [2, 3, 5, 7, 11, 13, 17, 19, 23]

kernel = torch.ones((1, 1, 3, 3, 3), device=device).float()
kernel[0, 0, 1, 1, 1] = 0

def run_poole(f):
    with torch.no_grad():
        padded = torch.nn.functional.pad(f.float(), (1,1,1,1,1,1), mode='circular')
        potential = torch.nn.functional.conv3d(padded, kernel)
        resonance = torch.zeros_like(potential)
        for p in PRIMES:
            resonance += 0.35 * torch.exp(-((potential - p)**2) / 0.01)
        total_phi = potential + resonance
        birth = (f == 0) & (total_phi >= B_LOW) & (total_phi <= B_HIGH)
        survive = (f == 1) & (total_phi >= S_LOW) & (total_phi <= S_HIGH)
        return (birth | survive).float()

# === STABILIZATION PHASE ===
field = torch.zeros((1, 1, GRID_SIZE, GRID_SIZE, GRID_SIZE), device=device)
field[0, 0, GRID_SIZE//2-15:GRID_SIZE//2+15, GRID_SIZE//2-15:GRID_SIZE//2+15, GRID_SIZE//2-15:GRID_SIZE//2+15] = 0.6

print("Stabilizing Phoenix attractor background...")
for t in range(600):
    field = run_poole(field)
    if t % 200 == 0:
        print(f"Gen {t} — background density: {field.mean().item():.4f}")

# === ENTANGLED GEOMETRY SETUP ===
oy, ox, oz = GRID_SIZE//2, GRID_SIZE//2, GRID_SIZE//2

# 1. Carve the Outer Loop (Bit 1)
field[0,0, oy-45:oy+45, ox-55:ox+55, oz-3:oz+4] = 0   # clear channel
field[0,0, oy-40:oy+40, ox-50:ox+50, oz-2:oz+3] = 1.0  # walls

# 2. Carve the Inner Loop (Bit 0)
field[0,0, oy-25:oy+25, ox-35:ox+35, oz-3:oz+4] = 0
field[0,0, oy-20:oy+20, ox-30:ox+30, oz-2:oz+3] = 1.0

# 3. ENGINEER THE BRIDGE (Connecting Right sides)
# Clear the channel between the inner right wall and outer right wall
field[0,0, oy-4:oy+4, ox+30:ox+50, oz-3:oz+4] = 0 
# Build the top and bottom walls of the bridge to guide the mass
field[0,0, oy-5:oy-4, ox+30:ox+50, oz-2:oz+3] = 1.0 # Top bridge wall
field[0,0, oy+4:oy+5, ox+30:ox+50, oz-2:oz+3] = 1.0 # Bottom bridge wall

# 4. Inject a SINGLE packet into the Inner Loop only
# The outer loop is completely dead at generation 0
field[0,0, oy-22:oy-18, ox-32:ox-28, oz-2:oz+3] = 1.0

print("\n=== INITIATING BRIDGE CROSS-TALK TEST (1200 generations) ===")
q1_history = []  # outer loop sensor
q0_history = []  # inner loop sensor
bridge_history = [] # new sensor in the corridor

for t in range(1200):
    field = run_poole(field)
    
    # Sensors
    q1_mass = int(field[0,0, oy-42:oy-38, ox-5:ox+5, oz].sum().item())   # outer
    q0_mass = int(field[0,0, oy-22:oy-18, ox-5:ox+5, oz].sum().item())   # inner
    bridge_mass = int(field[0,0, oy-3:oy+3, ox+35:ox+45, oz].sum().item()) # corridor
    
    if t % 100 == 0:
        q1_history.append(q1_mass)
        q0_history.append(q0_mass)
        bridge_history.append(bridge_mass)
        print(f"Gen {t:4d} | Inner: {q0_mass:3d} | Bridge: {bridge_mass:3d} | Outer: {q1_mass:3d}")

# Final visualization
fig, (ax1, ax2, ax3) = plt.subplots(1, 3, figsize=(15, 5), facecolor='black')

ax1.plot(q0_history, color='cyan', label='Inner Loop (Source)')
ax2.plot(bridge_history, color='magenta', label='Bridge Corridor')
ax3.plot(q1_history, color='gold', label='Outer Loop (Receiver)')

ax1.set_title("Source Mass", color='white')
ax2.set_title("Transfer Mass", color='white')
ax3.set_title("Received Mass", color='white')

for ax in (ax1, ax2, ax3):
    ax.set_xlabel("Time (×100 gens)", color='white')
    ax.set_ylabel("Kinetic Mass", color='white')
    ax.legend()
    ax.grid(True, alpha=0.3)
    ax.tick_params(colors='white')

plt.tight_layout()
plt.show()

print("✅ Bridge test complete.")
