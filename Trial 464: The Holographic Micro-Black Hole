# POOLE MANIFOLD — Trial 464: The Holographic Micro-Black Hole
# =============================================================================

import torch
import numpy as np
import matplotlib.pyplot as plt
import time

device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print(f"🚀 Initializing Poole Manifold Holographic Singularity Engine on: {device}")

N = 300
CENTER = N // 2
Y, X = torch.meshgrid(torch.arange(N, device=device, dtype=torch.float32), 
                      torch.arange(N, device=device, dtype=torch.float32), indexing='ij')

R = torch.sqrt((X - CENTER)**2 + (Y - CENTER)**2) + 1e-5
Dir_X = (X - CENTER) / R
Dir_Y = (Y - CENTER) / R

# --- 1. INITIALIZE EMPTY VACUUM ---
# The universe is completely empty except for a baseline hum of zero-point energy
u = 0.05 * torch.randn_like(X)
u_prev = u.clone()

# Physics Constants
c2 = 0.45
damping = 0.999
horizon_radius = 15.0

T_MAX = 500
mass_history = []
spin_history = []

print("-" * 50)
print(" -> T=000: Vacuum stable. Establishing Holographic Entanglement Horizon...")
start_time = time.time()

for t in range(T_MAX + 1):
    u_pad = torch.nn.functional.pad(u.unsqueeze(0).unsqueeze(0), (1,1,1,1), mode='replicate').squeeze()
    
    # Internal scalar cohesion
    laplacian = u_pad[2:, 1:-1] + u_pad[:-2, 1:-1] + u_pad[1:-1, 2:] + u_pad[1:-1, :-2] - 4.0 * u
    u_next = 2.0 * u - damping * u_prev + c2 * laplacian
    
    # --- 2. THE HOLOGRAPHIC BOUNDARY ---
    # We define a 2D spherical boundary condition (The Event Horizon)
    horizon_mask = (R > horizon_radius - 1.5) & (R < horizon_radius + 1.5)
    
    grad_x = u_pad[1:-1, 2:] - u_pad[1:-1, :-2]
    grad_y = u_pad[2:, 1:-1] - u_pad[:-2, 1:-1]
    
    # Inward gravity generated PURELY by the boundary's surface entanglement with the vacuum
    holographic_pull = 0.08 * R * (Dir_X * grad_x + Dir_Y * grad_y) * horizon_mask
    
    # Frame-dragging: The boundary naturally induces quantum spin (torsion)
    theta = torch.atan2(Y - CENTER, X - CENTER)
    torsion = 0.03 * torch.sin(theta + t * 0.1) * horizon_mask * u
    
    u_next += holographic_pull + torsion
    
    u_prev = u
    u = u_next
    
    # --- 3. TELEMETRY & DIAGNOSTICS ---
    # We measure the energy trapped INSIDE the empty boundary
    interior_mass = torch.sum(torch.abs(u[R < horizon_radius])).item()
    
    # Measure total system angular momentum
    L_z = X * grad_y - Y * grad_x
    total_spin = torch.sum(L_z[R < horizon_radius + 5]).item()
    
    mass_history.append(interior_mass)
    spin_history.append(total_spin)
    
    if t % 100 == 0:
        print(f" -> T={t:03d} | Interior Holographic Mass: {interior_mass:08.2f} | Quantum Spin: {total_spin:08.2f}")

print("-" * 50)
print(f"### HOLOGRAPHIC SINGULARITY DIAGNOSTIC (T={time.time() - start_time:.2f}s) ###")
print("Status: HORIZON SEALED. Particle mass derived entirely from vacuum surface entanglement.")

# --- 4. HOLOGRAPHIC RENDERING ---
plt.figure(figsize=(15, 5), facecolor='black')

# Plot 1: Mass Accumulation
plt.subplot(1, 3, 1)
plt.plot(mass_history, color='cyan', linewidth=2, label="Interior Mass")
plt.title("Holographic Mass Generation", color='white')
plt.xlabel("Generation", color='white')
plt.ylabel("Trapped Phi Potential", color='white')
plt.grid(True, color='gray', alpha=0.3)
plt.legend()

# Plot 2: Angular Momentum
plt.subplot(1, 3, 2)
plt.plot(spin_history, color='magenta', linewidth=2, label="Angular Spin ($L_z$)")
plt.title("Spontaneous Torsion", color='white')
plt.xlabel("Generation", color='white')
plt.ylabel("Net Rotation Vector", color='white')
plt.grid(True, color='gray', alpha=0.3)
plt.legend()

# Plot 3: The Micro-Singularity
plt.subplot(1, 3, 3)
plt.title(f"Quantum Black Hole at T={T_MAX}", color='white')
limit = np.max(np.abs(u.cpu().numpy())) * 0.8
plt.imshow(u.cpu().numpy(), cmap='inferno', vmin=-limit, vmax=limit)
plt.axis('off')

plt.tight_layout()
plt.show()
