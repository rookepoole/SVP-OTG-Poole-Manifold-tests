# =============================================================================
# POOLE MANIFOLD — Multi-Bit Shift Register / Memory Tape Test
# =============================================================================

import torch
import numpy as np
import matplotlib.pyplot as plt
import torch.nn.functional as F

device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print(f"🚀 Multi-Bit Shift Register Test on: {device}")

# --- Engine ---
B_LOW, B_HIGH = 5.0, 7.0
S_LOW, S_HIGH = 5.0, 9.0
GRID_SIZE = 420
PRIMES = [2, 3, 5, 7, 11, 13, 17, 19, 23]

kernel = torch.ones((1, 1, 3, 3, 3), device=device).float()
kernel[0, 0, 1, 1, 1] = 0

def run_manifold(f):
    with torch.no_grad():
        padded = F.pad(f.float(), (1,1,1,1,1,1), mode='circular')
        potential = F.conv3d(padded, kernel)
        resonance = torch.zeros_like(potential)
        for p in PRIMES:
            resonance += 0.35 * torch.exp(-((potential - p)**2) / 0.01)
        total_phi = potential + resonance
        birth = (f == 0) & (total_phi >= B_LOW) & (total_phi <= B_HIGH)
        survive = (f == 1) & (total_phi >= S_LOW) & (total_phi <= S_HIGH)
        return (birth | survive).float()

# ====================== STABILIZE ======================
print("Stabilizing to Phoenix attractor...")
field = torch.zeros((1, 1, GRID_SIZE, GRID_SIZE, GRID_SIZE), device=device)
center = GRID_SIZE // 2
field[0, 0, center-80:center+80, center-80:center+80, center-80:center+80] = (torch.rand(160,160,160, device=device) > 0.69).float()

for t in range(800):
    field = run_manifold(field)
    if t % 100 == 0:
        print(f"Gen {t} — density: {field.mean().item():.4f}")

# ====================== LONG LINEAR MEMORY TAPE ======================
print("\nBuilding long linear memory tape...")
oy = GRID_SIZE // 2
tape_ox_start = 60
tape_length = 280

# Create a long horizontal delay-line channel
field[0,0, oy-25:oy+25, tape_ox_start:tape_ox_start+tape_length, GRID_SIZE//2-3:GRID_SIZE//2+4] = 0   # clear channel
field[0,0, oy-20:oy+20, tape_ox_start:tape_ox_start+tape_length, GRID_SIZE//2-2:GRID_SIZE//2+3] = 1.0 # walls

# Inject a test pattern (e.g. 1 0 1 1)
pattern = [1, 0, 1, 1]
for i, bit in enumerate(pattern):
    if bit:
        field[0,0, oy-18:oy-14, tape_ox_start + 20 + i*30 : tape_ox_start + 24 + i*30, GRID_SIZE//2-2:GRID_SIZE//2+3] = 1.0

print("Running shift register test (1200 generations)...")
sensor_readings = []

for t in range(1200):
    field = run_manifold(field)
    
    if t % 50 == 0:
        # Read the end of the tape (shifted output)
        end_mass = int(field[0,0, oy-18:oy-14, tape_ox_start+tape_length-40:tape_ox_start+tape_length-10, GRID_SIZE//2].sum().item())
        sensor_readings.append(end_mass)
        print(f"Gen {t:4d} | End-of-tape mass: {end_mass}")

# Plot the shift behavior
plt.figure(figsize=(10, 5), facecolor='black')
plt.plot(sensor_readings, color='cyan', linewidth=2)
plt.title("Memory Tape Shift Register Output", color='white')
plt.xlabel("Time (×50 gens)", color='white')
plt.ylabel("Mass at end of tape", color='white')
plt.grid(True, alpha=0.3)
plt.tight_layout()
plt.show()

print("\nShift register test complete.")
