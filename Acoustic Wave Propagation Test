import torch
import torch.nn.functional as F
import numpy as np
import matplotlib.pyplot as plt
from IPython.display import clear_output

device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
print(f"Using device: {device} — Acoustic Wave Propagation Test online!")
def poole_manifold_step(grid):
    kernel = torch.ones((1, 1, 3, 3, 3), device=device, dtype=torch.float32)
    kernel[0, 0, 1, 1, 1] = 0
    padded = F.pad(grid.unsqueeze(0).unsqueeze(0), (1,1,1,1,1,1), mode='circular')
    neighbor_sum = F.conv3d(padded, kernel, padding=0).squeeze(0).squeeze(0)
    
    born = (neighbor_sum >= 5) & (neighbor_sum <= 7) & (grid == 0)
    survive = (neighbor_sum >= 5) & (neighbor_sum <= 9) & (grid == 1)
    return (born | survive).float()

print("✅ Poole Manifold engine ready!")
np.random.seed(42)
size = 80
grid_np = np.zeros((size, size, size), dtype=np.float32)

# Cosmic web filaments
for _ in range(220):
    x = np.random.randint(0, size)
    y = np.random.randint(0, size)
    z = np.random.randint(0, size)
    length = np.random.randint(25, 55)
    dx = np.random.randn() * 1.3
    dy = np.random.randn() * 1.3
    dz = np.random.randn() * 1.3
    for i in range(length):
        ix = int(x + i * dx) % size
        iy = int(y + i * dy) % size
        iz = int(z + i * dz) % size
        if 0 <= ix < size and 0 <= iy < size and 0 <= iz < size:
            grid_np[ix, iy, iz] = 1.0

noise = np.random.choice([0, 1], size=(size, size, size), p=[0.85, 0.15])
grid_np = np.clip(grid_np + noise, 0, 1)

grid = torch.from_numpy(grid_np).float().to(device)

# Wave field (pressure amplitude)
wave = torch.zeros((size, size, size), device=device, dtype=torch.float32)

print(f"Porous network initialized — {grid.sum().item():.0f} solid cells")
steps = 3000
density_history = []
wave_history = []

print("Running FINAL TUNED Acoustic Wave Propagation Test...")

for step in range(steps):
    grid = poole_manifold_step(grid)
    
    # Ultra-gentle wave propagation
    padded_w = F.pad(wave.unsqueeze(0).unsqueeze(0), (1,1,1,1,1,1), mode='circular')
    diffused = F.avg_pool3d(padded_w, kernel_size=3, stride=1, padding=0).squeeze(0).squeeze(0)
    
    # Extremely slow damping: almost lossless in pores, mild in solid
    pores = (grid < 0.5)
    wave = torch.where(pores, diffused * 0.992, diffused * 0.96)
    
    # Sharp pulse injection every 800 steps (left face)
    if step % 800 == 0:
        wave[0:8, :, :] = 1.0
    
    if step % 500 == 0 or step == steps-1:
        density = grid.mean().item()
        avg_wave = wave.mean().item()
        density_history.append((step, density))
        wave_history.append((step, avg_wave))
        print(f"Step {step:4d} | Density: {density:.4f} | Avg Wave Amplitude: {avg_wave:.4f}")
        
        if step % 1000 == 0 or step == steps-1:
            clear_output(wait=True)
            center = size // 2
            fig, axes = plt.subplots(1, 3, figsize=(15,5))
            axes[0].imshow(grid[center].cpu().numpy(), cmap='binary')
            axes[0].set_title('Solid network (XY)')
            axes[1].imshow(wave[center].cpu().numpy(), cmap='plasma')
            axes[1].set_title('Wave Amplitude (XY)')
            axes[2].imshow(wave[:, center, :].cpu().numpy(), cmap='plasma')
            axes[2].set_title('Wave Amplitude (XZ)')
            plt.suptitle(f"FINAL TUNED Acoustic Wave Propagation — Step {step}")
            plt.show()

print("\n✅ FINAL TUNED Acoustic Wave Propagation test finished!")
steps_list, dens_list = zip(*density_history)
w_steps, w_list = zip(*wave_history)

plt.figure(figsize=(10,5))
plt.plot(steps_list, dens_list, 'b-', label='Solid density')
plt.axhline(y=0.31, color='r', linestyle='--', label='Phoenix ~31%')
plt.title('Density during Acoustic Test')
plt.legend()
plt.grid(True)
plt.show()

plt.figure(figsize=(10,5))
plt.plot(w_steps, w_list, 'cyan', label='Average wave amplitude')
plt.title('Wave Amplitude Over Time')
plt.xlabel('Step')
plt.ylabel('Mean amplitude')
plt.legend()
plt.grid(True)
plt.show()

final_grid = grid.cpu().numpy() > 0.5
porosity = 1 - final_grid.mean()
print(f"Porosity: {porosity:.4f} ({porosity*100:.1f}%)")
print(f"Final average wave amplitude: {wave.mean().item():.4f}")

np.save('acoustic_final_grid.npy', final_grid.astype(np.uint8))
np.save('acoustic_final_wave.npy', wave.cpu().numpy())
print("Saved acoustic data!")
