# 1. THE CANONICAL PHYSICS ENGINE
# =============================================================================
class PooleEngine:
    def __init__(self, device=None):
        self.device = device if device else torch.device("cuda" if torch.cuda.is_available() else "cpu")
        self.B_LOW, self.B_HIGH = 5.0, 7.0 
        self.S_LOW, self.S_HIGH = 5.0, 9.0
        self.primes = [2.0, 3.0, 5.0, 7.0, 11.0, 13.0, 17.0, 19.0, 23.0]
        self.sigma_sq = 0.01
        self.alpha = 0.35
        self.kernel = torch.ones((1, 1, 3, 3, 3), device=self.device).float()
        self.kernel[0, 0, 1, 1, 1] = 0.0

    def step(self, f_tensor, inhibitor=None, threshold=None, amplifier=None):
        with torch.no_grad():
            f_float = f_tensor.float()
            # Padding for standard computation
            padded = F.pad(f_float, (1, 1, 1, 1, 1, 1), mode='circular')
            potential = F.conv3d(padded, self.kernel, padding=0)
            
            if inhibitor is not None: potential = torch.where(inhibitor, potential - 15.0, potential)
            if threshold is not None: potential = torch.where(threshold, potential - 2.0, potential)
            if amplifier is not None: potential = torch.where(amplifier, potential + 1.0, potential)
            
            resonance = torch.zeros_like(potential)
            for p in self.primes:
                resonance += self.alpha * torch.exp(-((potential - p) ** 2) / self.sigma_sq)
            
            total_phi = potential + resonance
            birth = (f_tensor == 0) & (total_phi >= self.B_LOW) & (total_phi <= self.B_HIGH)
            survive = (f_tensor == 1) & (total_phi >= self.S_LOW) & (total_phi <= self.S_HIGH)
            
            del f_float, padded, potential, resonance, total_phi
            return (birth | survive).to(torch.int8)

# =============================================================================
# 2. THE WORM RECEIPT GENERATOR (Patched)
# =============================================================================
class WORMReceipt:
    @staticmethod
    def hash_field(data):
        if isinstance(data, torch.Tensor):
            return hashlib.sha256(data.cpu().numpy().tobytes()).hexdigest()
        elif isinstance(data, dict):
            return hashlib.sha256(json.dumps(data, sort_keys=True).encode()).hexdigest()
        else:
            return hashlib.sha256(str(data).encode()).hexdigest()

    @staticmethod
    def generate_receipt(experiment_name, seed, initial_state, final_state, metrics):
        receipt = {
            "protocol": "Delta RPM Protocol",
            "experiment": experiment_name,
            "timestamp": time.time(),
            "seed": seed,
            "initial_state_hash": WORMReceipt.hash_field(initial_state),
            "final_state_hash": WORMReceipt.hash_field(final_state),
            "telemetry": metrics
        }
        
        receipt_string = json.dumps(receipt, sort_keys=True).encode()
        receipt["receipt_sha256"] = hashlib.sha256(receipt_string).hexdigest()
        
        filename = f"RECEIPT_{experiment_name.replace(' ', '_')}_{int(time.time())}.json"
        with open(filename, "w") as f:
            json.dump(receipt, f, indent=4)
            
        return filename, receipt

    @staticmethod
    def verify_receipt(filepath):
        if not os.path.exists(filepath):
            return False, "File not found."
            
        with open(filepath, "r") as f:
            receipt = json.load(f)
            
        # Non-destructive dictionary copy for verification
        stored_hash = receipt.get("receipt_sha256")
        receipt_copy = {k: v for k, v in receipt.items() if k != "receipt_sha256"}
        recalculated_hash = hashlib.sha256(json.dumps(receipt_copy, sort_keys=True).encode()).hexdigest()
        
        if stored_hash == recalculated_hash:
            return True, "WORM Seal Intact."
        else:
            return False, "WORM Seal BROKEN."

