TEST_REGISTRY = []
RESULTS = {"passed": 0, "failed": 0, "failures": []}

def register_test(name):
    def decorator(func):
        TEST_REGISTRY.append((name, func))
        return func
    return decorator

# --- Core Physics Tests ---
@register_test("Lattice Initialization & Tensor Allocation")
def test_init():
    engine = PooleEngine(device=torch.device("cpu"))
    grid = torch.zeros((1, 1, 10, 10, 10), dtype=torch.int8)
    assert grid.shape == (1, 1, 10, 10, 10), "Tensor allocation failed."
    return True

@register_test("B5-7/S5-9 Empty Vacuum Survival (Zero Mass)")
def test_vacuum():
    engine = PooleEngine(device=torch.device("cpu"))
    grid = torch.zeros((1, 1, 10, 10, 10), dtype=torch.int8)
    next_grid = engine.step(grid)
    assert next_grid.sum().item() == 0, "Vacuum spawned spontaneous mass."
    return True

@register_test("B5-7/S5-9 Overpopulation Collapse (Thermal Evaporation)")
def test_overpopulation():
    engine = PooleEngine(device=torch.device("cpu"))
