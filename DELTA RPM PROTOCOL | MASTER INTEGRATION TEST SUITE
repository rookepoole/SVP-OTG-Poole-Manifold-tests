@register_test("WORM Receipt Generation & Non-Destructive Verification")
def test_cryptography():
    grid_initial = torch.zeros((1, 1, 5, 5, 5), dtype=torch.int8)
    grid_final = torch.ones((1, 1, 5, 5, 5), dtype=torch.int8)
    
    filename, receipt_data = WORMReceipt.generate_receipt(
        "Unit_Test", 42, grid_initial, grid_final, {"test_metric": 100}
