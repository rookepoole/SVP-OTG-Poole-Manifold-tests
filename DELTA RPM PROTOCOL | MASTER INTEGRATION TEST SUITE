    grid[0, 0, 4:7, 4:7, 4:7] = 1 # 27 solid voxels
    next_grid = engine.step(grid)
    assert next_grid[0, 0, 5, 5, 5].item() == 0, "Core failed to evaporate above S_HIGH=9.0."
