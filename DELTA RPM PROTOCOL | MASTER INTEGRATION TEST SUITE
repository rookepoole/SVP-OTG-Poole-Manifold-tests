    print("==================================================")
    
    if RESULTS["failed"] == 0:
        print("[+] System Integrity: VERIFIED. Engine is cleared for operation.")
    else:
        print("[-] System Integrity: COMPROMISED. Do not run production audits.")

if __name__ == "__main__":
