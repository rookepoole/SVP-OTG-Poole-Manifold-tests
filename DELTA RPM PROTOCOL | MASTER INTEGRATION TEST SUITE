# --- EXECUTOR ---
def run_all_tests():
    print(f"Executing {len(TEST_REGISTRY)} registered Delta RPM tests...\n")
    for name, func in TEST_REGISTRY:
        try:
            passed = func()
            if passed:
                print(f"[PASS] {name}")
                RESULTS["passed"] += 1
        except AssertionError as e:
            print(f"[FAIL] {name} - {str(e)}")
            RESULTS["failed"] += 1
            RESULTS["failures"].append((name, str(e)))
        except Exception as e:
            print(f"[ERROR] {name} - {str(e)}")
            RESULTS["failed"] += 1
            RESULTS["failures"].append((name, str(e)))
            
    print("\n==================================================")
    print("DELTA RPM PROTOCOL — ENGINE TEST RESULTS")
