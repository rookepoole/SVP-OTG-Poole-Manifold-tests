import torch
import torch.nn.functional as F
import numpy as np
import matplotlib.pyplot as plt
from IPython.display import clear_output

device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
print(f"Using device: {device} — Fracture Test online!")
def poole_manifold_step(grid):
    kernel = torch.ones((1, 1, 3, 3, 3), device=device, dtype=torch.float32)
    kernel[0, 0, 1, 1, 1] = 0
    padded = F.pad(grid.unsqueeze(0).unsqueeze(0), (1,1,1,1,1,1), mode='circular')
    neighbor_sum = F.conv3d(padded, kernel, padding=0).squeeze(0).squeeze(0)
    
    born = (neighbor_sum >= 5) & (neighbor_sum <= 7) & (grid == 0)
    survive = (neighbor_sum >= 5) & (neighbor_sum <= 9) & (grid == 1)
    return (born | survive).float()

print("✅ Porous network engine ready!")
np.random.seed(42)
size = 80
grid_np = np.zeros((size, size, size), dtype=np.float32)

# Cosmic web filaments
for _ in range(220):
    x = np.random.randint(0, size)
    y = np.random.randint(0, size)
    z = np.random.randint(0, size)
    length = np.random.randint(25, 55)
    dx = np.random.randn() * 1.3
    dy = np.random.randn() * 1.3
    dz = np.random.randn() * 1.3
    for i in range(length):
        ix = int(x + i * dx) % size
        iy = int(y + i * dy) % size
        iz = int(z + i * dz) % size
        if 0 <= ix < size and 0 <= iy < size and 0 <= iz < size:
            grid_np[ix, iy, iz] = 1.0

noise = np.random.choice([0, 1], size=(size, size, size), p=[0.85, 0.15])
grid_np = np.clip(grid_np + noise, 0, 1)

grid = torch.from_numpy(grid_np).float().to(device)

print(f"Porous network initialized — {grid.sum().item():.0f} solid cells")
steps = 3000
density_history = []
broken_history = []

print("Running FINAL TUNED Fracture / Crack Propagation Test...")

for step in range(steps):
    grid = poole_manifold_step(grid)
    
    # === FINAL TUNED CRACK LOGIC ===
    if step == 800:
        # One-time jagged crack seed at center
        mid = size // 2
        for y in range(size):
            for z in range(size):
                if np.random.rand() < 0.75:
                    grid[mid, y, z] = 0.0
    
    if step > 800 and step % 50 == 0:   # only every 50 steps = much slower propagation
        # Narrower band + much gentler weakening
        x_idx = torch.arange(size, device=device).view(-1, 1, 1)
        crack_band = (torch.abs(x_idx - size//2) < 4).expand_as(grid)  # narrower band
        grid[crack_band] = torch.where(grid[crack_band] > 0.5, 
                                       grid[crack_band] * 0.97,   # very gentle
                                       grid[crack_band])
    
    broken_cells = (grid < 0.5).sum().item()
    
    if step % 500 == 0 or step == steps-1:
        density = grid.mean().item()
        density_history.append((step, density))
        broken_history.append((step, broken_cells / (size**3)))
        print(f"Step {step:4d} | Density: {density:.4f} | Broken fraction: {broken_cells / (size**3):.4f}")
        
        if step % 1000 == 0 or step == steps-1:
            clear_output(wait=True)
            center = size // 2
            fig, axes = plt.subplots(1, 3, figsize=(15,5))
            axes[0].imshow(grid[center].cpu().numpy(), cmap='binary')
            axes[0].set_title('Solid network (XY)')
            axes[1].imshow(grid[:, center, :].cpu().numpy(), cmap='binary')
            axes[1].set_title('Crack view (XZ)')
            axes[2].imshow(grid[:, :, center].cpu().numpy(), cmap='binary')
            axes[2].set_title('Crack view (YZ)')
            plt.suptitle(f"FINAL TUNED Fracture Test — Step {step}")
            plt.show()

print("\n✅ FINAL TUNED Fracture test finished!")
steps_list, dens_list = zip(*density_history)
b_steps, b_list = zip(*broken_history)

plt.figure(figsize=(10,5))
plt.plot(steps_list, dens_list, 'b-', label='Solid density')
plt.axhline(y=0.31, color='r', linestyle='--', label='Phoenix ~31%')
plt.title('Density during Fracture')
plt.legend()
plt.grid(True)
plt.show()

plt.figure(figsize=(10,5))
plt.plot(b_steps, b_list, 'orange', label='Broken fraction')
plt.title('Crack Propagation Over Time')
plt.xlabel('Step')
plt.ylabel('Fraction of broken cells')
plt.legend()
plt.grid(True)
plt.show()

final_grid = grid.cpu().numpy() > 0.5
porosity = 1 - final_grid.mean()
print(f"Porosity: {porosity:.4f} ({porosity*100:.1f}%)")
print(f"Final broken fraction: {b_list[-1]:.4f}")

np.save('fracture_final_grid.npy', final_grid.astype(np.uint8))
print("Saved fracture data!")
