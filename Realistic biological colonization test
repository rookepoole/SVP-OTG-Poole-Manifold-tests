import torch
import torch.nn.functional as F
import numpy as np
import matplotlib.pyplot as plt
from IPython.display import clear_output

device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
print(f"Using device: {device} — Realistic Biological Colonization online!")
def poole_manifold_step(grid):
    kernel = torch.ones((1, 1, 3, 3, 3), device=device, dtype=torch.float32)
    kernel[0, 0, 1, 1, 1] = 0
    padded = F.pad(grid.unsqueeze(0).unsqueeze(0), (1,1,1,1,1,1), mode='circular')
    neighbor_sum = F.conv3d(padded, kernel, padding=0).squeeze(0).squeeze(0)
    
    born = (neighbor_sum >= 5) & (neighbor_sum <= 7) & (grid == 0)
    survive = (neighbor_sum >= 5) & (neighbor_sum <= 9) & (grid == 1)
    return (born | survive).float()

print("✅ Porous network engine ready!")
np.random.seed(42)
size = 80
grid_np = np.zeros((size, size, size), dtype=np.float32)

# Cosmic web background
for _ in range(220):
    x = np.random.randint(0, size)
    y = np.random.randint(0, size)
    z = np.random.randint(0, size)
    length = np.random.randint(25, 55)
    dx = np.random.randn() * 1.3
    dy = np.random.randn() * 1.3
    dz = np.random.randn() * 1.3
    for i in range(length):
        ix = int(x + i * dx) % size
        iy = int(y + i * dy) % size
        iz = int(z + i * dz) % size
        if 0 <= ix < size and 0 <= iy < size and 0 <= iz < size:
            grid_np[ix, iy, iz] = 1.0

noise = np.random.choice([0, 1], size=(size, size, size), p=[0.85, 0.15])
grid_np = np.clip(grid_np + noise, 0, 1)

grid = torch.from_numpy(grid_np).float().to(device)

# Biological cells (live = 1.0, dead = -1.0)
cells = torch.zeros((size, size, size), device=device, dtype=torch.float32)

# Seed 120 small clusters randomly in pores
for _ in range(120):
    cx = np.random.randint(5, size-5)
    cy = np.random.randint(5, size-5)
    cz = np.random.randint(5, size-5)
    if grid[cx, cy, cz] < 0.5:
        cells[cx-1:cx+2, cy-1:cy+2, cz-1:cz+2] = 1.0

# Nutrient field (starts high near solid filaments)
nutrient = torch.zeros((size, size, size), device=device, dtype=torch.float32)
nutrient[grid > 0.5] = 1.0  # solid filaments are nutrient sources

print(f"Porous network + realistic cell seed initialized — {grid.sum().item():.0f} solid cells, { (cells > 0).sum().item():.0f} initial live cells")
steps = 4000
density_history = []
colonization_history = []
viability_history = []

print("Realistic biological colonization started...")

for step in range(steps):
    grid = poole_manifold_step(grid)
    
    # Nutrient diffusion from solid filaments
    padded_nut = F.pad(nutrient.unsqueeze(0).unsqueeze(0), (1,1,1,1,1,1), mode='circular')
    diffused_nut = F.avg_pool3d(padded_nut, kernel_size=3, stride=1, padding=0).squeeze(0).squeeze(0)
    nutrient = diffused_nut * 0.85 + (grid * 0.15)  # decay + replenishment from solid
    
    # Cell growth rules
    empty = (grid < 0.5)
    live = (cells > 0)
    
    # Grow only where nutrient is sufficient and space is available
    padded_cells = F.pad(cells.unsqueeze(0).unsqueeze(0), (1,1,1,1,1,1), mode='circular')
    growth_potential = F.avg_pool3d(padded_cells, kernel_size=3, stride=1, padding=0).squeeze(0).squeeze(0) > 0.2
    growth = empty & growth_potential & (nutrient > 0.3)
    cells = torch.where(growth, cells + 0.6, cells)   # slower growth
    
    # Cell death: isolated or low nutrient
    death = live & ((nutrient < 0.15) | (torch.sum((cells > 0).float(), dim=0) > 20))
    cells = torch.where(death, -1.0, cells)
    cells = torch.clamp(cells, -1.0, 1.0)
    
    if step % 500 == 0 or step == steps-1:
        density = grid.mean().item()
        live_cells = (cells > 0).sum().item()
        colonized = (cells > 0).float().mean().item()
        viability = live_cells / max(1, (cells != 0).sum().item())
        
        density_history.append((step, density))
        colonization_history.append((step, colonized))
        viability_history.append((step, viability))
        
        print(f"Step {step:4d} | Density: {density:.4f} | Colonized: {colonized:.4f} | Viability: {viability:.3f}")
        
        if step % 1000 == 0 or step == steps-1:
            clear_output(wait=True)
            center = size // 2
            fig, axes = plt.subplots(1, 3, figsize=(15,5))
            axes[0].imshow(grid[center].cpu().numpy(), cmap='binary')
            axes[0].set_title('Solid network (XY)')
            axes[1].imshow(cells[center].cpu().numpy(), cmap='RdYlGn')
            axes[1].set_title('Cells (live=green, dead=red)')
            axes[2].imshow(nutrient[center].cpu().numpy(), cmap='plasma')
            axes[2].set_title('Nutrient level (XZ)')
            plt.suptitle(f"Realistic Colonization — Step {step}")
            plt.show()

print("\n✅ Realistic biological colonization test finished!")
steps_list, dens_list = zip(*density_history)
col_steps, col_list = zip(*colonization_history)
via_steps, via_list = zip(*viability_history)

plt.figure(figsize=(10,5))
plt.plot(steps_list, dens_list, 'b-', label='Solid density')
plt.axhline(y=0.31, color='r', linestyle='--', label='Phoenix ~31%')
plt.title('Density during Realistic Colonization')
plt.legend()
plt.grid(True)
plt.show()

plt.figure(figsize=(10,5))
plt.plot(col_steps, col_list, 'green', label='Colonized fraction')
plt.plot(via_steps, via_list, 'orange', label='Cell viability')
plt.title('Biological Cell Growth & Viability Over Time')
plt.xlabel('Step')
plt.ylabel('Fraction')
plt.legend()
plt.grid(True)
plt.show()

final_grid = grid.cpu().numpy() > 0.5
final_live = cells.cpu().numpy() > 0
porosity = 1 - final_grid.mean()
colonized_fraction = final_live[~final_grid].mean()
viability = final_live.sum() / max(1, (cells != 0).sum().item())

print(f"Porosity: {porosity:.4f} ({porosity*100:.1f}%)")
print(f"Final colonized fraction of pore space: {colonized_fraction:.4f} ({colonized_fraction*100:.1f}%)")
print(f"Final cell viability: {viability:.3f} ({viability*100:.1f}%)")

np.save('realistic_colonization_grid.npy', final_grid.astype(np.uint8))
np.save('realistic_colonization_cells.npy', (cells.cpu().numpy() > 0).astype(np.uint8))
print("Saved realistic colonization data!")
