import torch
import torch.nn.functional as F
import numpy as np
import matplotlib.pyplot as plt
from IPython.display import clear_output
import time

device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
print(f"Using device: {device} — EM Shielding Engine Ready!")

size = 80

def poole_manifold_step(grid):
    kernel = torch.ones((1, 1, 3, 3, 3), device=device, dtype=torch.float32)
    kernel[0, 0, 1, 1, 1] = 0
    padded = F.pad(grid.unsqueeze(0).unsqueeze(0), (1,1,1,1,1,1), mode='circular')
    neighbor_sum = F.conv3d(padded, kernel, padding=0).squeeze(0).squeeze(0)
    born = (neighbor_sum >= 5) & (neighbor_sum <= 7) & (grid == 0)
    survive = (neighbor_sum >= 5) & (neighbor_sum <= 9) & (grid == 1)
    return (born | survive).float()
    torch.manual_seed(42)
np.random.seed(42)
grid = torch.zeros((size, size, size), device=device, dtype=torch.float32)

for _ in range(220):
    x0 = np.random.randint(0, size)
    y0 = np.random.randint(0, size)
    z0 = np.random.randint(0, size)
    length = np.random.randint(25, 55)
    dx = np.random.choice([-1, 1])
    dy = np.random.choice([-1, 1])
    dz = np.random.choice([-1, 1])
    for i in range(length):
        x = (x0 + i * dx) % size
        y = (y0 + i * dy) % size
        z = (z0 + i * dz) % size
        grid[x, y, z] = 1.0

noise = (torch.rand(size, size, size, device=device) < 0.15).float()
grid = torch.clamp(grid + noise, 0, 1)

print(f"Initial grid ready — {int(grid.sum().item())} live cells")
em_wave = torch.zeros((size, size, size), device=device, dtype=torch.float32)
print("EM wave field ready — Shielding test loaded")
steps = 4000
density_history = []
em_history = []
transmission_history = []

print("Running Electromagnetic Shielding Test...\n")

for step in range(steps):
    grid = poole_manifold_step(grid)
    
    # Oscillating EM pulses (simulates RF/microwave)
    if step % 250 == 0:
        em_wave[0:6, :, :] = torch.sin(torch.tensor(step / 50.0, device=device)) * 0.8 + 0.6
    
    # Propagation with absorption on filaments
    padded_em = F.pad(em_wave.unsqueeze(0).unsqueeze(0), (1,1,1,1,1,1), mode='circular')
    diffused = F.avg_pool3d(padded_em, kernel_size=3, stride=1, padding=0).squeeze(0).squeeze(0)
    pores = (grid < 0.5)
    em_wave = torch.where(pores, diffused * 0.99, diffused * 0.88)  # strong absorption on solid
    
    # Metrics
    density = grid.mean().item()
    avg_em = em_wave.mean().item()
    transmission = em_wave[-1, :, :].mean().item() * 100  # % transmitted through right face
    
    density_history.append(density)
    em_history.append(avg_em)
    transmission_history.append(transmission)
    
    if step % 500 == 0 or step == steps - 1:
        clear_output(wait=True)
        print(f"Step {step:4d} | Density: {density:.4f} | Avg EM: {avg_em:.4f} | Transmission: {transmission:.1f}%")
        
        center = size // 2
        fig, axes = plt.subplots(1, 3, figsize=(18, 5))
        axes[0].imshow(grid[center].cpu().numpy(), cmap='binary')
        axes[0].set_title('Solid Network (XY)')
        axes[1].imshow(em_wave[center].cpu().numpy(), cmap='plasma')
        axes[1].set_title('EM Wave (XY)')
        axes[2].imshow(em_wave[:, center, :].cpu().numpy(), cmap='plasma')
        axes[2].set_title('EM Wave (XZ)')
        plt.suptitle(f'EM Shielding Test — Step {step} | Transmission: {transmission:.1f}%')
        plt.show()

print(f"\n✅ EM Shielding Test finished!")
print(f"Final porosity: {1-grid.mean().item():.4f} ({(1-grid.mean().item())*100:.1f}%)")
print(f"Final transmission: {transmission_history[-1]:.1f}%")
np.save('em_shielding_final_grid.npy', grid.cpu().numpy())
np.save('em_shielding_final_em.npy', em_wave.cpu().numpy())
