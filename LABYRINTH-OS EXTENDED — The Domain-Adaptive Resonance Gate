        total_epistemic_mass = 0.0
        base_readings = []
        
        # 1. Calculate Base Epistemic Mass
        for channel, value in sensor_readings.items():
            res = self.calculate_channel_resonance(channel, value)
            
            # =================================================================
            # The Venturi Choke:
            # If resonance falls below 0.05, the contradiction is too deep. 
            # The epistemic wavefunction immediately collapses.
            # =================================================================
            if res < 0.05:
                print(f" > Channel [{channel:<10}] | Value: {value:.3f} | Resonance: {res:.3f} 💥 CHOKE TRIGGERED")
                print(f"[X] GATE BLOWOUT: Fatal contradiction detected in {channel}. Wave packet collapsed.")
                return False
            # =================================================================
            
            total_epistemic_mass += res
            base_readings.append(value)
            print(f" > Channel [{channel:<10}] | Value: {value:.3f} | Resonance: +{res:.3f}")

        # 2. Apply Physical Masks (Historical Memory)
        proposal_vector = np.array(base_readings)
        inhibitor, amplifier = self.memory.get_historical_masks(proposal_vector)
        
        final_epistemic_mass = total_epistemic_mass + amplifier - inhibitor
        
        print(f" > Memory Modifiers   | Amplifier: +{amplifier:.3f} | Inhibitor: -{inhibitor:.3f}")
        print(f" > FINAL MASS         | {final_epistemic_mass:.3f} / Threshold: {self.PROMOTION_THRESHOLD}")

        # 3. The Gate Decision
        if final_epistemic_mass >= self.PROMOTION_THRESHOLD:
            print("[✓] GATE OPEN: Proposal promoted to execution ledger.")
            return True
        else:
            print("[X] GATE CLOSED: Insufficient epistemic mass. Routing to Healing Loop.")
            return False

