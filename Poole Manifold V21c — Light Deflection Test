import torch
import torch.nn.functional as F
import matplotlib.pyplot as plt
from tqdm import tqdm
import numpy as np
import gc

device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print(f"🚀 Poole Manifold V21c — Light Deflection Test (Improved Tracking) on: {device}")

torch.cuda.empty_cache()
gc.collect()

GRID_SIZE = 448
PRIMES = [2, 3, 5, 7, 11, 13, 17, 19, 23]
B_LOW, B_HIGH = 5.0, 7.0
S_LOW, S_HIGH = 5.0, 9.0

kernel = torch.ones((1, 1, 3, 3, 3), device=device).float()
kernel[0, 0, 1, 1, 1] = 0

def run_manifold(field):
    with torch.no_grad():
        mag = field.abs().float().unsqueeze(0).unsqueeze(0)
        padded = F.pad(mag, (1, 1, 1, 1, 1, 1), mode='circular')
        potential = F.conv3d(padded, kernel, padding=0).squeeze(0).squeeze(0)

        resonance = torch.zeros_like(potential, device=device)
        for p in PRIMES:
            resonance += 0.35 * torch.exp(-((potential - p) ** 2) / 0.01)

        total = potential + resonance

        prob = (total ** 2).clamp(0, 1)
        rand = torch.rand_like(field.real, device=device)
        
        birth = (field.abs() < 1e-6) & (rand < prob)
        survive = (field.abs() >= 1e-6) & (rand < prob)

        amplitude = total / (1 + total.abs() + 1e-8)
        new_field = torch.where(birth | survive, amplitude, torch.zeros_like(field, device=device))
        return new_field

# ====================== MACRO-ORBIT ======================
def stamp_macro_orbit(field, center, radius=22, amp=3.0):
    x = torch.arange(GRID_SIZE, device=device)
    X, Y, Z = torch.meshgrid(x, x, x, indexing='ij')
    r = torch.sqrt((X - center[0])**2 + (Y - center[1])**2 + (Z - center[2])**2)
    ring = (r > radius-4) & (r < radius+3)
    eye  = r < radius-9
    field[ring] = amp
    field[eye]  = 0.0
    return field

# ====================== INITIALIZATION ======================
field = torch.zeros((GRID_SIZE, GRID_SIZE, GRID_SIZE), dtype=torch.complex64, device=device)
center = (GRID_SIZE//2, GRID_SIZE//2, GRID_SIZE//2)
field = stamp_macro_orbit(field, center)

# ====================== PHOTON LAUNCH ======================
impact_params = np.array([20, 35, 50, 70, 90, 120, 160, 210])
trajectories_x = [[] for _ in impact_params]
trajectories_y = [[] for _ in impact_params]

X, Y, Z = torch.meshgrid(torch.arange(GRID_SIZE, device=device),
                         torch.arange(GRID_SIZE, device=device),
                         torch.arange(GRID_SIZE, device=device), indexing='ij')

for i, b in enumerate(impact_params):
    photon = torch.zeros_like(field, dtype=torch.complex64, device=device)
    x0 = GRID_SIZE // 6
    y0 = GRID_SIZE // 2 + int(b)
    z0 = GRID_SIZE // 2
    sigma = 4.0
    gauss = torch.exp(-((X - x0)**2 + (Y - y0)**2 + (Z - z0)**2) / (2 * sigma**2))
    photon += gauss * 0.9
    field += photon.to(torch.complex64)

# ====================== EVOLUTION & TRACKING ======================
TOTAL_STEPS = 320
for t in tqdm(range(TOTAL_STEPS), desc="Light Deflection Test"):
    field = run_manifold(field)
    
    density = field.abs() ** 2
    for i, b in enumerate(impact_params):
        y_target = GRID_SIZE // 2 + int(b)
        # Tight mask around expected photon location
        mask = (X > GRID_SIZE//3) & (X < GRID_SIZE*2//3) & \
               (Y > y_target-15) & (Y < y_target+15)
        mass = density[mask].sum()
        if mass > 1e-8:
            com_x = (density[mask] * X[mask]).sum() / mass
            com_y = (density[mask] * Y[mask]).sum() / mass
            trajectories_x[i].append(com_x.item())
            trajectories_y[i].append(com_y.item())

# ====================== DEFLECTION ANALYSIS ======================
deflections = []
initial_x = GRID_SIZE // 6

for i in range(len(impact_params)):
    if len(trajectories_x[i]) < 2:
        deflections.append(0.0)
        continue
    dx = trajectories_x[i][-1] - initial_x
    dy = trajectories_y[i][-1] - trajectories_y[i][0]
    theta_rad = np.arctan2(dy, dx)
    theta_deg = np.degrees(theta_rad)
    deflections.append(theta_deg)

# GR weak-field prediction (scaled)
b_values = np.array(impact_params, dtype=float)
gr_deflection = (4.0 / b_values) * (180 / np.pi)

print("\n✅ Light Deflection Results (V21c)")
print("Impact Parameter b (cells) | Measured Deflection (deg) | GR Prediction (scaled)")
for b, meas, gr in zip(impact_params, deflections, gr_deflection):
    print(f"{b:3d}                          | {meas:6.2f}                    | {gr:6.2f}")

# ====================== PLOTS ======================
plt.figure(figsize=(12, 6), facecolor='black')
ax = plt.gca(); ax.set_facecolor('black')
for i, (tx, ty) in enumerate(zip(trajectories_x, trajectories_y)):
    ax.plot(tx, label=f'b={impact_params[i]}')
ax.set_title("V21c — Photon Trajectories around Central Macro-Orbit", color='white')
ax.set_xlabel("Time step (propagation distance)", color='white')
ax.set_ylabel("X position (cells)", color='white')
ax.legend(); ax.tick_params(colors='white'); ax.grid(True, color='gray', alpha=0.3)
plt.tight_layout(); plt.show()

plt.figure(figsize=(8, 6), facecolor='black')
ax = plt.gca(); ax.set_facecolor('black')
ax.scatter(impact_params, deflections, color='#ff00ff', s=80, label='Measured deflection')
ax.plot(impact_params, gr_deflection, '--', color='white', label='GR weak-field prediction (scaled)')
ax.set_title("V21c — Light Deflection vs Impact Parameter", color='white')
ax.set_xlabel("Impact Parameter b (cells)", color='white')
ax.set_ylabel("Deflection angle (degrees, scaled)", color='white')
ax.legend(); ax.tick_params(colors='white'); ax.grid(True, color='gray', alpha=0.3)
plt.tight_layout(); plt.show()
