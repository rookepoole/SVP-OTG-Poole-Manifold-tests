        history['Mem_B'].append(field[0, 0, 15:105, 135:225, z_mid].sum().item())
        
        # ALU Output Sensor (Placed far down the straight pipe to catch the surviving wave)
        history['ALU_Out'].append(field[0, 0, 200:220, 175:185, z_mid].sum().item())

    print(">> T=600: Cycle Complete. Rendering ALU Telemetry...")

