# ==========================================
# TEMPORAL LATCH EXECUTION
# ==========================================
def run_alu_cycle():
    GRID_Y, GRID_X, GRID_Z = 240, 260, 10
    z_mid = 5
    
    field = torch.zeros((1, 1, GRID_Y, GRID_X, GRID_Z), device=device)
    base_inhibitor_mask = torch.ones_like(field).bool()
    threshold_mask = torch.zeros_like(field).bool()
    amplifier_mask = torch.zeros_like(field).bool()

    alu = PooleDualRegisterALU(z_mid=z_mid)
    alu.stamp(base_inhibitor_mask, threshold_mask, amplifier_mask)

    history = {'Mem_A': [], 'Mem_B': [], 'ALU_Out': []}
    
    print("--- COMMENCING DUAL-REGISTER ALU CYCLE (V47: The T-Bone Architecture) ---")
    
    for t in range(601): 
        current_inh_mask = base_inhibitor_mask.clone()

        # 1. WRITE BOTH REGISTERS (A = 1, B = 1)
        if 10 <= t <= 40:
            field[0, 0, 52:56, 58:62, z_mid-1:z_mid+1] = 1.0 # Set A
            field[0, 0, 2:6, 178:182, z_mid-1:z_mid+1] = 1.0 # Set B

        # 2. SURGICAL CLOCK FLUSH (Kill A, Clean the T-Bone Intersection)
        if 230 <= t <= 245:
            # Kill Register A AND Valve A entirely
            current_inh_mask[0, 0, 0:165, 10:105, z_mid-2:z_mid+2] = True
            # Kill Bus A explicitly
            current_inh_mask[0, 0, 135:145, 100:179, z_mid-2:z_mid+2] = True
            # Drop concrete on the Intersection AND the Exhaust directly below it to wipe the knot
            current_inh_mask[0, 0, 135:240, 175:185, z_mid-2:z_mid+2] = True

        if t > 0:
            field[0, 0, :, :, :] = torch.where(amplifier_mask, field[0, 0, :, :, :], field[0, 0, :, :, :])

        field = run_manifold(field, current_inh_mask, threshold_mask, amplifier_mask)

        # TELEMETRY
