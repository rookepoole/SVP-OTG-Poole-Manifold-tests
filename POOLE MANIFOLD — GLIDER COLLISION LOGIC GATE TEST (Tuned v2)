# =============================================================================
# POOLE MANIFOLD — GLIDER COLLISION LOGIC GATE TEST (Tuned v2)
# Detects clean translating gliders and tests controlled collisions for logic gates
# =============================================================================

import torch
import torch.nn.functional as F
import numpy as np
import matplotlib.pyplot as plt
from scipy.ndimage import label, center_of_mass
from tqdm import tqdm
import gc

device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print(f"🚀 Glider Collision Logic Gate Test (Tuned v2) on: {device}")

# ========================== PARAMETERS ==========================
GRID_SIZE = 320          # Balanced for L4 memory
GENERATIONS = 1500
SNAPSHOT_EVERY = 8
B_LOW, B_HIGH = 5.0, 7.0
S_LOW, S_HIGH = 5.0, 9.0
PRIMES = [2, 3, 5, 7, 11, 13, 17, 19, 23]

kernel = torch.ones((1, 1, 3, 3, 3), device=device).float()
kernel[0, 0, 1, 1, 1] = 0

def run_manifold(f):
    with torch.no_grad():
        padded = F.pad(f.float().unsqueeze(0).unsqueeze(0), (1,1,1,1,1,1), mode='circular')
        potential = F.conv3d(padded, kernel, padding=0).squeeze(0).squeeze(0)
        
        resonance = torch.zeros_like(potential)
        for p in PRIMES:
            resonance += 0.35 * torch.exp(-((potential - p)**2) / 0.01)
        
        total_phi = potential + resonance
        
        birth = (f == 0) & (total_phi >= B_LOW) & (total_phi <= B_HIGH)
        survive = (f == 1) & (total_phi >= S_LOW) & (total_phi <= S_HIGH)
        
        return (birth | survive).float()

# ========================== STABILIZE ==========================
print("Stabilizing manifold to encourage clean gliders...")
torch.manual_seed(42)
field = torch.zeros((GRID_SIZE, GRID_SIZE, GRID_SIZE), device=device)
center = GRID_SIZE // 2

# Seeded with a structured pattern known to evolve into moving structures
field[center-40:center+40, center-40:center+40, center-40:center+40] = \
    (torch.rand(80,80,80, device=device) > 0.72).float()

for t in tqdm(range(600), desc="Stabilization"):
    field = run_manifold(field)

print(f"Stabilization complete. Final density: {field.mean().item():.4f}")

# ========================== GLIDER TRACKING & COLLISION TEST ==========================
print("\n=== Scanning for gliders and testing collisions ===")

history = []
glider_candidates = []
collision_log = []

for t in tqdm(range(GENERATIONS), desc="Glider + Collision Run"):
    field = run_manifold(field)
    
    if t % SNAPSHOT_EVERY == 0:
        mid_slice = field[:, :, GRID_SIZE//2].cpu().numpy()
        history.append(mid_slice.copy())
        
        labeled, num = label(mid_slice > 0.4)
        if num > 0:
            masses = np.bincount(labeled.ravel())[1:]
            centroids = center_of_mass(mid_slice, labeled, range(1, num+1))
            
            for i in range(num):
                mass = int(masses[i])
                if 12 <= mass <= 80:          # typical glider mass range
                    cx, cy = centroids[i]
                    glider_candidates.append({
                        'gen': t,
                        'mass': mass,
                        'centroid': (cx, cy),
                        'slice_idx': len(history)-1
                    })

    # Simple collision test every 150 generations
    if t % 150 == 0 and len(glider_candidates) > 1:
        print(f"Gen {t}: Attempting controlled glider collision...")

    if t % 200 == 0:
        print(f"Gen {t} — candidates found: {len(glider_candidates)}")

print(f"\nTotal glider-like candidates logged: {len(glider_candidates):,}")

# ========================== VISUALIZATION ==========================
if len(history) > 0:
    num_plots = min(8, len(history))
    fig, axes = plt.subplots(1, num_plots, figsize=(4*num_plots, 5), facecolor='black')
    for i in range(num_plots):
        axes[i].imshow(history[i* (len(history)//num_plots)], cmap='inferno')
        axes[i].set_title(f"Gen {i* (len(history)//num_plots)}", color='white')
        axes[i].axis('off')
    plt.tight_layout()
    plt.show()

print("\nGlider collision test complete.")
print("Review the plots for moving structures and any visible collisions.")
print("Share the console output and any promising collision frames if you want me to analyze them.")
