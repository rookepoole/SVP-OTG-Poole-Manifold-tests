# =============================================================================
# POOLE MANIFOLD — Sci-Fi Test 2: Multiverse / Parallel Lattice Tunneling
# Two parallel universes with rare tunneling events
# =============================================================================

import torch
import torch.nn.functional as F
import numpy as np
import matplotlib.pyplot as plt
from IPython.display import clear_output

device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print(f"🚀 Sci-Fi Test 2 — Multiverse / Parallel Lattice Tunneling on: {device}")

GRID_SIZE = 160
B_LOW, B_HIGH = 5.0, 7.0
S_LOW, S_HIGH = 5.0, 9.0
PRIMES = [2, 3, 5, 7, 11, 13, 17, 19, 23]

kernel = torch.ones((1, 1, 3, 3, 3), device=device).float()
kernel[0, 0, 1, 1, 1] = 0

def run_manifold(f):
    with torch.no_grad():
        padded = F.pad(f.float(), (1,1,1,1,1,1), mode='circular')
        potential = F.conv3d(padded, kernel)
        resonance = torch.zeros_like(potential)
        for p in PRIMES:
            resonance += 0.35 * torch.exp(-((potential - p)**2) / 0.01)
        total_phi = potential + resonance
        birth = (f == 0) & (total_phi >= B_LOW) & (total_phi <= B_HIGH)
        survive = (f == 1) & (total_phi >= S_LOW) & (total_phi <= S_HIGH)
        return (birth | survive).float()

# Two parallel layers (Layer 0 and Layer 1)
layer0 = (torch.rand((1, 1, GRID_SIZE, GRID_SIZE, GRID_SIZE), device=device) > 0.69).float()
layer1 = (torch.rand_like(layer0) > 0.72).float()

print("Two parallel universes seeded. Stabilizing...")

for _ in range(600):
    layer0 = run_manifold(layer0)
    layer1 = run_manifold(layer1)

print("✅ Multiverse test running! Watching for tunneling events...\n")

tunneling_count = 0
correlation_history = []

for gen in range(3200):
    layer0 = run_manifold(layer0)
    layer1 = run_manifold(layer1)
    
    # Rare tunneling events (high-energy portals)
    if gen % 120 == 0 and torch.rand(1).item() < 0.35:
        # Create a small portal between layers
        portal_y, portal_x, portal_z = GRID_SIZE//2 + np.random.randint(-20,20), GRID_SIZE//2 + np.random.randint(-20,20), GRID_SIZE//2
        layer0[0, 0, portal_z:portal_z+6, portal_y:portal_y+6, portal_x:portal_x+6] = layer1[0, 0, portal_z:portal_z+6, portal_y:portal_y+6, portal_x:portal_x+6] * 0.7
        layer1[0, 0, portal_z:portal_z+6, portal_y:portal_y+6, portal_x:portal_x+6] = layer0[0, 0, portal_z:portal_z+6, portal_y:portal_y+6, portal_x:portal_x+6] * 0.7
        tunneling_count += 1
        print(f"🔄 Tunneling event #{tunneling_count} at Gen {gen}")

    if gen % 40 == 0:
        corr = torch.corrcoef(torch.stack([layer0.flatten(), layer1.flatten()]))[0,1].item()
        correlation_history.append(corr)
        
        slice0 = layer0[0,0,GRID_SIZE//2].cpu().numpy()
        slice1 = layer1[0,0,GRID_SIZE//2].cpu().numpy()
        
        clear_output(wait=True)
        fig, axs = plt.subplots(1, 3, figsize=(18, 6), facecolor='black')
        
        axs[0].imshow(slice0, cmap='inferno')
        axs[0].set_title("Universe 0", color='white')
        axs[0].axis('off')
        
        axs[1].imshow(slice1, cmap='plasma')
        axs[1].set_title("Universe 1", color='white')
        axs[1].axis('off')
        
        axs[2].plot(correlation_history, color='magenta', linewidth=2)
        axs[2].set_title(f"Tunneling Events: {tunneling_count} | Correlation", color='white')
        axs[2].set_xlabel("Generation / 40", color='white')
        axs[2].grid(True, alpha=0.3)
        
        plt.show()

print("\n✅ Multiverse Tunneling Test complete!")
print(f"Total tunneling events: {tunneling_count}")
print(f"Final inter-universe correlation: {correlation_history[-1]:.4f}")

# Final summary
plt.figure(figsize=(10, 5), facecolor='black')
plt.plot(correlation_history, color='magenta', linewidth=2)
plt.title("Inter-Universe Correlation Over Time", color='white')
plt.xlabel("Generation / 40", color='white')
plt.ylabel("Correlation", color='white')
plt.grid(True, alpha=0.3)
plt.show()
