# =============================================================================
# POOLE MANIFOLD — Sci-Fi Test 1 v2: Tweaked Closed Timelike Curve
# Larger loop + internal guiding current + stronger isolation
# =============================================================================

import torch
import torch.nn.functional as F
import numpy as np
import matplotlib.pyplot as plt
from IPython.display import clear_output

device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print(f"🚀 Sci-Fi Test 1 v2 — Tweaked Closed Timelike Curve on: {device}")

GRID_SIZE = 192
B_LOW, B_HIGH = 5.0, 7.0
S_LOW, S_HIGH = 5.0, 9.0
PRIMES = [2, 3, 5, 7, 11, 13, 17, 19, 23]

kernel = torch.ones((1, 1, 3, 3, 3), device=device).float()
kernel[0, 0, 1, 1, 1] = 0

def run_manifold(f):
    with torch.no_grad():
        padded = F.pad(f.float(), (1,1,1,1,1,1), mode='circular')
        potential = F.conv3d(padded, kernel)
        resonance = torch.zeros_like(potential)
        for p in PRIMES:
            resonance += 0.35 * torch.exp(-((potential - p)**2) / 0.01)
        total_phi = potential + resonance
        birth = (f == 0) & (total_phi >= B_LOW) & (total_phi <= B_HIGH)
        survive = (f == 1) & (total_phi >= S_LOW) & (total_phi <= S_HIGH)
        return (birth | survive).float()

# Initialize
field = torch.zeros((1, 1, GRID_SIZE, GRID_SIZE, GRID_SIZE), device=device)
field = (torch.rand_like(field) > 0.69).float()

# Larger closed timelike loop
loop_y, loop_x, loop_z = 48, 48, GRID_SIZE//2
loop_size = 96

# Outer ring
field[0, 0, loop_z:loop_z+loop_size, loop_y:loop_y+loop_size, loop_x:loop_x+loop_size] = 1.0
# Inner clear space
field[0, 0, loop_z+8:loop_z+loop_size-8, loop_y+8:loop_y+loop_size-8, loop_x+8:loop_x+loop_size-8] = 0.0

# Strong isolation walls around the entire loop
field[0, 0, loop_z-6:loop_z+loop_size+6, loop_y-6:loop_y+loop_size+6, loop_x-6:loop_x+loop_size+6] = 0.0
field[0, 0, loop_z:loop_z+loop_size, loop_y:loop_y+loop_size, loop_x:loop_x+loop_size] = 1.0  # restore outer ring

# Internal guiding current (conveyor belt inside the loop)
current_bias = torch.zeros_like(field)
current_bias[0, 0, loop_z+12:loop_z+loop_size-12, loop_y+12:loop_y+loop_size-12, loop_x+12:loop_x+loop_size-12] = 0.25

# Seed one controlled glider packet to start circulation
field[0, 0, loop_z+20:loop_z+24, loop_y+14:loop_y+18, loop_x+14:loop_x+18] = 1.0

print("Tweaked closed timelike loop seeded. Stabilizing...")

for _ in range(600):
    field = run_manifold(field)

print("✅ Tweaked time-loop test running! Monitoring stability...\n")

loop_mass_history = []

for gen in range(3000):
    field = run_manifold(field)
    
    # Apply gentle internal current every step
    field = torch.clamp(field + 0.08 * current_bias, 0.0, 1.0)
    
    if gen % 20 == 0:
        loop_mass = field[0, 0, loop_z+8:loop_z+loop_size-8, 
                          loop_y+8:loop_y+loop_size-8, 
                          loop_x+8:loop_x+loop_size-8].sum().item()
        loop_mass_history.append(loop_mass)
        
        slice_mid = field[0, 0, loop_z, :, :].cpu().numpy()
        
        clear_output(wait=True)
        fig, axs = plt.subplots(1, 2, figsize=(16, 7), facecolor='black')
        
        axs[0].imshow(slice_mid, cmap='inferno')
        rect = plt.Rectangle((loop_x, loop_y), loop_size, loop_size, linewidth=2, edgecolor='cyan', facecolor='none')
        axs[0].add_patch(rect)
        axs[0].set_title(f"Closed Timelike Loop v2 (Gen {gen})", color='white')
        axs[0].axis('off')
        
        axs[1].plot(loop_mass_history, color='lime', linewidth=2)
        axs[1].set_title("Loop Mass Stability (higher = more stable circulation)", color='white')
        axs[1].set_xlabel("Generation / 20", color='white')
        axs[1].set_ylabel("Mass inside loop", color='white')
        axs[1].grid(True, alpha=0.3)
        
        plt.show()
        
        print(f"Gen {gen:4d} | Loop mass: {loop_mass:.1f} | Stable circulation?")

print("\n✅ Test 1 v2 complete!")
print("If the loop mass stays high and relatively steady, the lattice supports a closed timelike curve.")
print("If it still oscillates wildly, the loop remains unstable even with tweaks.")

# Final summary plot
plt.figure(figsize=(10, 5), facecolor='black')
plt.plot(loop_mass_history, color='lime', linewidth=2)
plt.title("Final Loop Mass Stability — Tweaked Closed Timelike Curve", color='white')
plt.xlabel("Generation / 20", color='white')
plt.ylabel("Mass inside the loop", color='white')
plt.grid(True, alpha=0.3)
plt.show()
