import torch
import torch.nn.functional as F
import numpy as np
import matplotlib.pyplot as plt
from IPython.display import clear_output
import time

device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
print(f"Using device: {device} — Bone Scaffold Engine Ready!")

size = 80

def poole_manifold_step(grid):
    kernel = torch.ones((1, 1, 3, 3, 3), device=device, dtype=torch.float32)
    kernel[0, 0, 1, 1, 1] = 0
    padded = F.pad(grid.unsqueeze(0).unsqueeze(0), (1,1,1,1,1,1), mode='circular')
    neighbor_sum = F.conv3d(padded, kernel, padding=0).squeeze(0).squeeze(0)
    born = (neighbor_sum >= 5) & (neighbor_sum <= 7) & (grid == 0)
    survive = (neighbor_sum >= 5) & (neighbor_sum <= 9) & (grid == 1)
    return (born | survive).float()
    torch.manual_seed(42)
np.random.seed(42)
grid = torch.zeros((size, size, size), device=device, dtype=torch.float32)

for _ in range(220):
    x0 = np.random.randint(0, size)
    y0 = np.random.randint(0, size)
    z0 = np.random.randint(0, size)
    length = np.random.randint(25, 55)
    dx = np.random.choice([-1, 1])
    dy = np.random.choice([-1, 1])
    dz = np.random.choice([-1, 1])
    for i in range(length):
        x = (x0 + i * dx) % size
        y = (y0 + i * dy) % size
        z = (z0 + i * dz) % size
        grid[x, y, z] = 1.0

noise = (torch.rand(size, size, size, device=device) < 0.15).float()
grid = torch.clamp(grid + noise, 0, 1)

print(f"Initial grid ready — {int(grid.sum().item())} live cells")
cells = torch.zeros((size, size, size), device=device, dtype=torch.float32)

# Seed initial cells on filaments (realistic colonization start)
cells = torch.where(grid > 0.5, torch.rand_like(cells) * 0.6 + 0.4, cells)

print("Cell population seeded on filaments — Bone scaffold ready")
steps = 5000  # longer run for biological realism
density_history = []
cell_history = []
viability_history = []
colonized_history = []

print("Running Bone-Mimetic Scaffold Test...\n")

for step in range(steps):
    grid = poole_manifold_step(grid)
    
    # Biological rules:
    # 1. Cells grow on filaments (if neighbors alive)
    # 2. Cells die in large pores
    # 3. Self-healing on damaged filaments
    pores = (grid < 0.5)
    live_neighbors = F.avg_pool3d(cells.unsqueeze(0).unsqueeze(0), kernel_size=3, stride=1, padding=1).squeeze(0).squeeze(0) * 26
    
    # Growth on filaments
    growth = (live_neighbors > 4) & (~pores) & (cells < 1.0)
    cells[growth] = torch.clamp(cells[growth] + 0.12, 0.0, 1.0)
    
    # Death in large pores
    death = (live_neighbors < 2) & pores
    cells[death] = torch.clamp(cells[death] - 0.25, 0.0, 1.0)
    
    # Self-healing
    heal = (cells < 0.3) & (~pores)
    cells[heal] = torch.clamp(cells[heal] + 0.18, 0.0, 1.0)
    
    # Metrics
    density = grid.mean().item()
    avg_cells = cells.mean().item()
    viability = (cells > 0.2).float().mean().item() * 100
    colonized = ((cells > 0.2) & (~pores)).float().mean().item() * 100
    
    density_history.append(density)
    cell_history.append(avg_cells)
    viability_history.append(viability)
    colonized_history.append(colonized)
    
    if step % 500 == 0 or step == steps - 1:
        clear_output(wait=True)
        print(f"Step {step:4d} | Density: {density:.4f} | Avg Cells: {avg_cells:.4f} | Viability: {viability:.1f}% | Colonized: {colonized:.1f}%")
        
        center = size // 2
        fig, axes = plt.subplots(1, 3, figsize=(18, 5))
        axes[0].imshow(grid[center].cpu().numpy(), cmap='binary')
        axes[0].set_title('Solid Network (XY)')
        axes[1].imshow(cells[center].cpu().numpy(), cmap='plasma')
        axes[1].set_title('Cell Viability (XY)')
        axes[2].imshow(cells[:, center, :].cpu().numpy(), cmap='plasma')
        axes[2].set_title('Cell Viability (XZ)')
        plt.suptitle(f'Bone Scaffold Test — Step {step} | Viability: {viability:.1f}%')
        plt.show()

print(f"\n✅ Bone-Mimetic Scaffold Test finished!")
print(f"Final porosity: {1-grid.mean().item():.4f} ({(1-grid.mean().item())*100:.1f}%)")
print(f"Final cell viability: {viability_history[-1]:.1f}%")
print(f"Final colonized fraction: {colonized_history[-1]:.1f}%")
np.save('bone_scaffold_final_grid.npy', grid.cpu().numpy())
np.save('bone_scaffold_final_cells.npy', cells.cpu().numpy())
