import torch
import torch.nn.functional as F
import matplotlib.pyplot as plt
from matplotlib.animation import FuncAnimation, PillowWriter

# Check if running in Google Colab to trigger automatic download
try:
    from google.colab import files
    IN_COLAB = True
except ImportError:
    IN_COLAB = False

# Hardware instantiation
device = torch.device("cuda" if torch.cuda.is_available() else "cpu")

# Thermodynamic Boundaries
B_LOW, B_HIGH = 5.0, 7.0
S_LOW, S_HIGH = 5.0, 9.0

# Harmonic Zeta Resonance Frequencies
PRIMES = [2, 3, 5, 7, 11, 13, 17, 19, 23]

# The Spherical Convolution Kernel
kernel = torch.ones((1, 1, 3, 3, 3), device=device).float()
kernel[0, 0, 1, 1, 1] = 0.0

def run_manifold(f, inhibitor_mask, threshold_mask, amplifier_mask):
    """Executes 1 tick of the OTG tensor physics."""
    with torch.no_grad():
        f_float = f.float()
        
        # PERIODIC BOUNDARY CONDITIONS: This makes the grid a "Macro-Latch" (a Toroidal Universe)
        padded = F.pad(f_float, (1, 1, 1, 1, 1, 1), mode='circular')
        
        potential = F.conv3d(padded, kernel, padding=0)
        potential = torch.where(inhibitor_mask, potential - 15.0, potential)
        potential = torch.where(threshold_mask, potential - 2.0, potential)
        potential = torch.where(amplifier_mask, potential + 1.0, potential)
        
        resonance = torch.zeros_like(potential)
        for p in PRIMES:
            resonance += 0.35 * torch.exp(-((potential - p)**2) / 0.01)
            
        total_phi = potential + resonance
        
        birth = (f == 0) & (total_phi >= B_LOW) & (total_phi <= B_HIGH)
        survive = (f == 1) & (total_phi >= S_LOW) & (total_phi <= S_HIGH)
        
        return (birth | survive).float()

def stamp_structure(inh, amp, start_y, start_x, is_finite=False):
    """Stamps a 20x20 latch. If is_finite=True, intentionally damages the thermodynamic armor."""
    ze = slice(3, 8)
    
    # Base 20x20 outer ring
    inh[0, 0, start_y:start_y+20, start_x:start_x+20, ze] = False
    amp[0, 0, start_y:start_y+20, start_x:start_x+20, ze] = True
    
    # 10x10 Inner eye (Inhibitor Void)
    inh[0, 0, start_y+5:start_y+15, start_x+5:start_x+15, ze] = True 
    amp[0, 0, start_y+5:start_y+15, start_x+5:start_x+15, ze] = False
    
    # Write Pin (Injection Runway)
    inh[0, 0, start_y-60:start_y+5, start_x-3:start_x, ze] = False
    amp[0, 0, start_y-60:start_y+5, start_x-3:start_x, ze] = True

    # SIMULATE RADIOACTIVE DECAY (Finite Latch)
    if is_finite:
        # We strip the +1.0 Amplifier Mask from the bottom-right corner.
        # This breaks the "weld" and ensures the geometry cannot survive the centrifugal pressure.
        amp[0, 0, start_y+15:start_y+20, start_x+15:start_x+20, ze] = False

# --- SIMULATION SETUP ---
# Creating a massive 300x300 grid to act as the Toroidal Macro-Latch
GRID_Y, GRID_X, GRID_Z = 300, 300, 10
field = torch.zeros((1, 1, GRID_Y, GRID_X, GRID_Z), device=device)
inh_mask = torch.ones_like(field).bool()
amp_mask = torch.zeros_like(field).bool()
thr_mask = torch.zeros_like(field).bool()

# Stamp the topologies
# Latch 1: Stable Baryonic Matter
stamp_structure(inh_mask, amp_mask, start_y=120, start_x=60, is_finite=False)
# Latch 2: Stable Baryonic Matter
stamp_structure(inh_mask, amp_mask, start_y=120, start_x=130, is_finite=False)
# Latch 3: Unstable Isotope (Finite Latch)
stamp_structure(inh_mask, amp_mask, start_y=120, start_x=200, is_finite=True)

# 250 frames is enough to watch the unstable isotope spin up, bleed out, and evaporate
TOTAL_FRAMES = 250 

# Setup the visual figure
fig, ax = plt.subplots(figsize=(10, 6), facecolor='black')
ax.set_facecolor('black')
im = ax.imshow(torch.zeros(120, 240).numpy(), cmap='magma', origin='upper', vmin=0, vmax=5)
ax.axis('off')
title = ax.set_title("OTG Fractal Topology: Immortal vs. Finite Latches | Frame: 0", color='white')

def update(t):
    global field
    
    # Ignition sequence: Fire fluid down all three pins simultaneously
    if 30 <= t < 80:
        field[0, 0, 60:63, 57:60, 3:8] = 1.0   # Pin 1
        field[0, 0, 60:63, 127:130, 3:8] = 1.0 # Pin 2
        field[0, 0, 60:63, 197:200, 3:8] = 1.0 # Pin 3
        
    # Enforce static +1.0 bounds
    if t > 0:
        field[0, 0, :, :, :] = torch.where(amp_mask, field[0, 0, :, :, :], field[0, 0, :, :, :])
        
    # Execute physics
    field = run_manifold(field, inh_mask, thr_mask, amp_mask)
    
    # Extract the 2D slice for rendering (zoomed in to see all three latches)
    render_frame = field[0, 0, 80:180, 40:240, :].sum(dim=-1).cpu().numpy()
    
    im.set_array(render_frame)
    title.set_text(f"OTG Fractal Topology: Immortal vs. Finite Latches | Frame: {t}")
    return [im, title]

print(f"Computing {TOTAL_FRAMES} frames of discrete tensor physics...")

# Generate the animation
anim = FuncAnimation(fig, update, frames=TOTAL_FRAMES, interval=40, blit=True)

output_filename = "otg_fractal_topology.gif"
print(f"Saving video to {output_filename}... Please wait.")

# Save via PillowWriter
anim.save(output_filename, writer=PillowWriter(fps=15))
plt.close(fig) 

print(f"Simulation successfully saved as '{output_filename}'.")

# Automatically prompt download if running in Colab
if IN_COLAB:
    print("Initiating download to your local machine...")
    files.download(output_filename)
