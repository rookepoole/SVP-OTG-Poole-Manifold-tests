# =============================================================================
# POOLE MANIFOLD — Sci-Fi Test 1: Self-Replicating von Neumann Probe
# Glider-based probe that reads a genome and builds copies of itself
# =============================================================================

import torch
import torch.nn.functional as F
import numpy as np
import matplotlib.pyplot as plt
from IPython.display import clear_output

device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print(f"🚀 Sci-Fi Test 1 — Self-Replicating von Neumann Probe on: {device}")

GRID_SIZE = 192
B_LOW, B_HIGH = 5.0, 7.0
S_LOW, S_HIGH = 5.0, 9.0
PRIMES = [2, 3, 5, 7, 11, 13, 17, 19, 23]

kernel = torch.ones((1, 1, 3, 3, 3), device=device).float()
kernel[0, 0, 1, 1, 1] = 0

def run_manifold(f):
    with torch.no_grad():
        padded = F.pad(f.float(), (1,1,1,1,1,1), mode='circular')
        potential = F.conv3d(padded, kernel)
        resonance = torch.zeros_like(potential)
        for p in PRIMES:
            resonance += 0.35 * torch.exp(-((potential - p)**2) / 0.01)
        total_phi = potential + resonance
        birth = (f == 0) & (total_phi >= B_LOW) & (total_phi <= B_HIGH)
        survive = (f == 1) & (total_phi >= S_LOW) & (total_phi <= S_HIGH)
        return (birth | survive).float()

# Initialize
field = torch.zeros((1, 1, GRID_SIZE, GRID_SIZE, GRID_SIZE), device=device)
field = (torch.rand_like(field) > 0.69).float()

# Seed the initial probe + genome packet
probe_y, probe_x, probe_z = 60, 60, GRID_SIZE//2
# Probe body (simple rectangular "ship")
field[0, 0, probe_z:probe_z+12, probe_y:probe_y+8, probe_x:probe_x+20] = 1.0
# Clear internal space
field[0, 0, probe_z+2:probe_z+10, probe_y+2:probe_y+6, probe_x+2:probe_x+18] = 0.0

# Genome packet (a small pattern that encodes replication instructions)
genome_y, genome_x = probe_y + 12, probe_x + 4
field[0, 0, probe_z+3:probe_z+7, genome_y:genome_y+4, genome_x:genome_x+12] = 1.0

print("Self-replicating probe seeded with genome packet. Stabilizing...")

for _ in range(800):
    field = run_manifold(field)

print("✅ Probe test running! Monitoring for replication events...\n")

replication_count = 0
probe_mass_history = []

for gen in range(4000):
    field = run_manifold(field)
    
    if gen % 30 == 0:
        # Measure mass in the original probe region
        probe_mass = field[0, 0, probe_z:probe_z+12, probe_y:probe_y+8, probe_x:probe_x+20].sum().item()
        probe_mass_history.append(probe_mass)
        
        # Check for new probes elsewhere (simple replication detector)
        total_mass = field.sum().item()
        if total_mass > 1.5 * probe_mass + 500:   # rough threshold for new copy
            replication_count += 1
            print(f"✅ Replication event detected! Total replications: {replication_count}")
        
        slice_mid = field[0, 0, GRID_SIZE//2, :, :].cpu().numpy()
        
        clear_output(wait=True)
        fig, axs = plt.subplots(1, 2, figsize=(16, 7), facecolor='black')
        
        axs[0].imshow(slice_mid, cmap='inferno')
        rect = plt.Rectangle((probe_x, probe_y), 20, 8, linewidth=2, edgecolor='cyan', facecolor='none')
        axs[0].add_patch(rect)
        axs[0].set_title(f"Self-Replicating Probe (Gen {gen})", color='white')
        axs[0].axis('off')
        
        axs[1].plot(probe_mass_history, color='lime', linewidth=2)
        axs[1].set_title(f"Probe Mass & Replication Count: {replication_count}", color='white')
        axs[1].set_xlabel("Generation / 30", color='white')
        axs[1].set_ylabel("Mass in original probe region", color='white')
        axs[1].grid(True, alpha=0.3)
        
        plt.show()

print("\n✅ Self-Replicating Probe Test complete!")
print(f"Total replication events detected: {replication_count}")
print("If replication_count > 0, the lattice supports true von Neumann self-replication.")

# Final summary plot
plt.figure(figsize=(10, 5), facecolor='black')
plt.plot(probe_mass_history, color='lime', linewidth=2)
plt.title("Final Probe Mass Stability", color='white')
plt.xlabel("Generation / 30", color='white')
plt.ylabel("Mass in original probe region", color='white')
plt.grid(True, alpha=0.3)
plt.show()
