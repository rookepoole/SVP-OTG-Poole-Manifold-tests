import torch
import torch.nn.functional as F
import numpy as np
import matplotlib.pyplot as plt
from IPython.display import clear_output
import time

device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
print(f"Using device: {device} — Filtration Engine Ready!")

size = 80

def poole_manifold_step(grid):
    kernel = torch.ones((1, 1, 3, 3, 3), device=device, dtype=torch.float32)
    kernel[0, 0, 1, 1, 1] = 0
    padded = F.pad(grid.unsqueeze(0).unsqueeze(0), (1,1,1,1,1,1), mode='circular')
    neighbor_sum = F.conv3d(padded, kernel, padding=0).squeeze(0).squeeze(0)
    born = (neighbor_sum >= 5) & (neighbor_sum <= 7) & (grid == 0)
    survive = (neighbor_sum >= 5) & (neighbor_sum <= 9) & (grid == 1)
    return (born | survive).float()
    torch.manual_seed(42)
np.random.seed(42)
grid = torch.zeros((size, size, size), device=device, dtype=torch.float32)

for _ in range(220):
    x0 = np.random.randint(0, size)
    y0 = np.random.randint(0, size)
    z0 = np.random.randint(0, size)
    length = np.random.randint(25, 55)
    dx = np.random.choice([-1, 1])
    dy = np.random.choice([-1, 1])
    dz = np.random.choice([-1, 1])
    for i in range(length):
        x = (x0 + i * dx) % size
        y = (y0 + i * dy) % size
        z = (z0 + i * dz) % size
        grid[x, y, z] = 1.0

noise = (torch.rand(size, size, size, device=device) < 0.15).float()
grid = torch.clamp(grid + noise, 0, 1)

print(f"Initial grid ready — {int(grid.sum().item())} live cells")
particles = torch.zeros((size, size, size), device=device, dtype=torch.float32)

# Continuous particle injection from left face (like incoming polluted air/water)
print("Particle injection field ready — Filtration test loaded")
steps = 4000
density_history = []
particle_history = []
efficiency_history = []
pressure_drop_history = []

print("Running Particle Filtration Test...\n")

for step in range(steps):
    grid = poole_manifold_step(grid)
    
    # Inject new particles from left
    if step % 200 == 0:
        particles[:8, :, :] = torch.rand(8, size, size, device=device) * 0.8 + 0.2
    
    # Particle diffusion + capture on filaments
    padded_p = F.pad(particles.unsqueeze(0).unsqueeze(0), (1,1,1,1,1,1), mode='circular')
    diffused_p = F.avg_pool3d(padded_p, kernel_size=3, stride=1, padding=0).squeeze(0).squeeze(0)
    
    pores = (grid < 0.5)
    particles = torch.where(pores, diffused_p * 0.98, diffused_p * 0.75)  # strong capture on solid
    
    # Capture probability on filaments
    capture_mask = (torch.rand_like(particles) < 0.12) & (~pores) & (particles > 0.3)
    particles[capture_mask] = 0.0
    
    # Metrics
    density = grid.mean().item()
    avg_particles = particles.mean().item()
    filtration_efficiency = (1.0 - avg_particles) * 100 if step > 0 else 0.0
    pressure_drop = (1.0 - particles.mean()) * 0.5  # proxy for flow resistance
    
    density_history.append(density)
    particle_history.append(avg_particles)
    efficiency_history.append(filtration_efficiency)
    pressure_drop_history.append(pressure_drop)
    
    if step % 500 == 0 or step == steps - 1:
        clear_output(wait=True)
        print(f"Step {step:4d} | Density: {density:.4f} | Avg Particles: {avg_particles:.4f} | Efficiency: {filtration_efficiency:.1f}% | Pressure Drop: {pressure_drop:.4f}")
        
        center = size // 2
        fig, axes = plt.subplots(1, 3, figsize=(18, 5))
        axes[0].imshow(grid[center].cpu().numpy(), cmap='binary')
        axes[0].set_title('Solid Network (XY)')
        axes[1].imshow(particles[center].cpu().numpy(), cmap='plasma')
        axes[1].set_title('Particle Concentration (XY)')
        axes[2].imshow(particles[:, center, :].cpu().numpy(), cmap='plasma')
        axes[2].set_title('Particle Concentration (XZ)')
        plt.suptitle(f'Filtration Test — Step {step} | Efficiency: {filtration_efficiency:.1f}%')
        plt.show()

print(f"\n✅ Filtration Test finished!")
print(f"Final porosity: {1-grid.mean().item():.4f} ({(1-grid.mean().item())*100:.1f}%)")
print(f"Final filtration efficiency: {efficiency_history[-1]:.1f}%")
np.save('filtration_final_grid.npy', grid.cpu().numpy())
np.save('filtration_final_particles.npy', particles.cpu().numpy())
