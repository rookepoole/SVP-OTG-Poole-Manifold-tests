# ================================================
# TEST C — GEODESIC DEVIATION / CURVATURE TEST
# Dense central macro-orbit + multiple test excitations
# ================================================
import torch
import torch.nn.functional as F
import numpy as np
import matplotlib.pyplot as plt
from tqdm import tqdm

device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print(f"Running on: {device}")

# Exact rules from your PDF
PRIMES = [2, 3, 5, 7, 11, 13, 17, 19, 23]
B_LOW, B_HIGH = 5.0, 7.0
S_LOW, S_HIGH = 5.0, 9.0

kernel = torch.ones((1, 1, 3, 3, 3), device=device, dtype=torch.float32)
kernel[0, 0, 1, 1, 1] = 0.0

def run_manifold(field):
    with torch.no_grad():
        padded = F.pad(field.unsqueeze(0).unsqueeze(0), (1,1,1,1,1,1), mode='circular')
        potential = F.conv3d(padded, kernel, padding=0).squeeze(0).squeeze(0)
        resonance = torch.zeros_like(potential)
        for p in PRIMES:
            resonance += 0.35 * torch.exp(-((potential - p)**2) / 0.01)
        total_phi = potential + resonance + 0.12 + 2.0
        birth = (field == 0) & (total_phi >= B_LOW) & (total_phi <= B_HIGH)
        survive = (field == 1) & (total_phi >= S_LOW) & (total_phi <= S_HIGH)
        return (birth | survive).float()

def stamp_macro_orbit(field, center, radius=12):
    x, y, z = torch.meshgrid(torch.arange(field.shape[0], device=device),
                             torch.arange(field.shape[1], device=device),
                             torch.arange(field.shape[2], device=device), indexing='ij')
    r = torch.sqrt((x-center[0])**2 + (y-center[1])**2 + (z-center[2])**2)
    amp_ring = (r >= radius-3) & (r <= radius+3)
    vacuum_eye = (r < radius-7)
    field[amp_ring] = 1.0
    field[vacuum_eye] = 0.0
    return field

GRID_SIZE = 448   # good resolution for curvature test

# Background + strong central "gravitational source"
field = torch.zeros((GRID_SIZE, GRID_SIZE, GRID_SIZE), device=device, dtype=torch.float32)
center = (GRID_SIZE//2, GRID_SIZE//2, GRID_SIZE//2)
field = stamp_macro_orbit(field, center, radius=18)   # dense central source

# Launch 6 test excitations at different impact parameters
impact_parameters = [0, 20, 40, 60, 80, 100]   # distance from central axis
trajectories = []
sigma = 8.0   # optimal compact seed from Test B

x, y, z = torch.meshgrid(torch.arange(GRID_SIZE, device=device),
                         torch.arange(GRID_SIZE, device=device),
                         torch.arange(GRID_SIZE, device=device), indexing='ij')

for impact in impact_parameters:
    print(f"\nLaunching test particle with impact parameter = {impact}")
    test_field = field.clone()
    
    # Launch from left side, offset by impact parameter
    launch_x = GRID_SIZE//4
    launch_y = GRID_SIZE//2 + impact
    launch_z = GRID_SIZE//2
    
    r = torch.sqrt((x - launch_x)**2 + (y - launch_y)**2 + (z - launch_z)**2)
    seed = 0.9 * torch.exp(-r**2 / (2 * sigma**2))
    test_field += seed
    test_field = torch.clamp(test_field, 0.0, 1.0)
    
    positions = []
    for t in tqdm(range(800), desc=f"Impact={impact}", leave=False):
        test_field = run_manifold(test_field)
        mask = (x > launch_x - 50) & (x < GRID_SIZE - 50) & \
               (y > launch_y - 120) & (y < launch_y + 120) & \
               (z > launch_z - 80) & (z < launch_z + 80)
        mass = test_field[mask].sum()
        if mass > 1e-4:
            cx = (test_field[mask] * x[mask]).sum() / mass
            cy = (test_field[mask] * y[mask]).sum() / mass
            cz = (test_field[mask] * z[mask]).sum() / mass
            positions.append((cx.item(), cy.item(), cz.item()))
    
    trajectories.append((impact, positions))

# ----------------- Results -----------------
print("\n" + "="*80)
print("GEODESIC DEVIATION RESULTS")
print("="*80)
print(f"{'Impact param':<15} {'Final x':<10} {'Deflection (Δy)':<15} {'Notes'}")
print("-"*80)

for impact, pos in trajectories:
    if len(pos) > 10:
        start_y = pos[0][1]
        final_y = pos[-1][1]
        deflection = final_y - start_y
        final_x = pos[-1][0]
        print(f"{impact:<15} {final_x:.1f}     {deflection:+.2f}          {'Deflected' if abs(deflection)>5 else 'Straight'}")
    else:
        print(f"{impact:<15} (dissipated)")

# Trajectory plot
plt.figure(figsize=(12, 8))
colors = plt.cm.viridis(np.linspace(0, 1, len(trajectories)))
for i, (impact, pos) in enumerate(trajectories):
    if len(pos) > 5:
        xs = [p[0] for p in pos]
        ys = [p[1] for p in pos]
        plt.plot(xs, ys, color=colors[i], lw=2, label=f'Impact={impact}')
plt.xlabel('x position')
plt.ylabel('y position')
plt.title('Trajectories around Central Macro-Orbit (Curvature Test)')
plt.legend()
plt.grid(True)
plt.show()
